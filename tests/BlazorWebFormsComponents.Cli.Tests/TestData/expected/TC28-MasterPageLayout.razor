@using System.Web.Optimization
@* TODO(bwfc-master-page): CSS <link> refs from <head> — move to App.razor: /Content/bootstrap.min.css, /Content/Site.css *@

<MasterPage>
<Head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contoso University - @(Page.Title)</title>
    @* Custom styles for the university theme *@
</Head>
<ChildContent>
    <form id="mainForm">
        <nav class="navbar navbar-default">
            <div class="container">
                <HyperLink NavigateUrl="/Default.aspx" CssClass="navbar-brand">
                    Contoso University
                </HyperLink>
                <ul class="nav navbar-nav">
                    <li><a href="/Students.aspx">Students</a></li>
                    <li><a href="/Courses.aspx">Courses</a></li>
                </ul>
                <AuthorizeView>
                    <NotAuthorized>
                        <a href="/Account/Login.aspx">Log in</a>
                    </NotAuthorized>
                    <Authorized>
                        <LoginName id="LoginName1" />
                    </Authorized>
                </AuthorizeView>
            </div>
        </nav>
        <div class="container body-content">
            <ContentPlaceHolder id="MainContent">
            </ContentPlaceHolder>
            <hr />
            <footer>
                <p>&copy; @(DateTime.Now.Year) - Contoso University</p>
            </footer>
        </div>
    </form>
</ChildContent>
</MasterPage>
