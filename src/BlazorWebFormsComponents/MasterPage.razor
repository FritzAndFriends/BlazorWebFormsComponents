@inherits MasterPageBase
@layout EmptyLayout

@if (Head != null)
{
	<HeadContent>
		@Head
	</HeadContent>
}

@if (Visible)
{
	<CascadingValue Value="this" IsFixed="false">
		<CascadingValue Value="Context" IsFixed="false">
			@ChildContent
			@ChildComponents
		</CascadingValue>
	</CascadingValue>
}
