@namespace BlazorWebFormsComponents.Theming
@inherits Microsoft.AspNetCore.Components.ComponentBase
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.DependencyInjection

@if (EffectiveTheme?.CssFiles != null && EffectiveTheme.CssFiles.Count > 0)
{
	<HeadContent>
		@foreach (var css in EffectiveTheme.CssFiles)
		{
			<link rel="stylesheet" href="@css" />
		}
	</HeadContent>
}

<CascadingValue Value="EffectiveTheme">
	@ChildContent
</CascadingValue>

@code {

	/// <summary>
	/// The theme configuration to cascade to child components.
	/// When null, falls back to a ThemeConfiguration registered via DI
	/// (e.g. auto-discovered from App_Themes by AddBlazorWebFormsComponents).
	/// </summary>
	[Parameter]
	public ThemeConfiguration Theme { get; set; }

	/// <summary>
	/// Controls how theme skins interact with explicit property values.
	/// Default is StyleSheetTheme (theme sets defaults, explicit values win).
	/// This parameter syncs with Theme.Mode.
	/// </summary>
	[Parameter]
	public ThemeMode Mode { get; set; } = ThemeMode.StyleSheetTheme;

	/// <summary>
	/// The child content that will receive the cascading theme.
	/// </summary>
	[Parameter]
	public RenderFragment ChildContent { get; set; }

	/// <summary>
	/// Service provider used to resolve an optional DI-registered ThemeConfiguration.
	/// </summary>
	[Inject]
	private IServiceProvider ServiceProvider { get; set; }

	/// <summary>
	/// The resolved theme: explicit Theme parameter wins, then DI fallback.
	/// </summary>
	private ThemeConfiguration EffectiveTheme { get; set; }

	protected override void OnParametersSet()
	{
		base.OnParametersSet();

		// Explicit parameter wins; fall back to DI-registered theme
		EffectiveTheme = Theme ?? ServiceProvider?.GetService<ThemeConfiguration>();

		// Sync Mode parameter to the effective theme
		if (EffectiveTheme != null)
		{
			EffectiveTheme.Mode = Mode;
		}
	}

}
