@inherits WebFormsPageBase

@if (!string.IsNullOrEmpty(CurrentTitle))
{
    <PageTitle>@CurrentTitle</PageTitle>
}
<HeadContent>
@if (!string.IsNullOrEmpty(CurrentMetaDescription))
{
    <meta name="description" content="@CurrentMetaDescription" />
}
@if (!string.IsNullOrEmpty(CurrentMetaKeywords))
{
    <meta name="keywords" content="@CurrentMetaKeywords" />
}
</HeadContent>
