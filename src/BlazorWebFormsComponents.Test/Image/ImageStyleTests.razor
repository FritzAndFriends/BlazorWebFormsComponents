@using static BlazorWebFormsComponents.WebColor
@using static BlazorWebFormsComponents.Enums.BorderStyle

@code {

	[Fact]
	public void Image_WithCssClass_RendersClassAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" CssClass="my-image" />);

		// Assert
		var img = cut.Find("img");
		img.HasAttribute("class").ShouldBeTrue();
		img.GetAttribute("class").ShouldBe("my-image");
	}

	[Fact]
	public void Image_WithBackColor_RendersBackgroundColorInStyle()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" BackColor="Yellow" />);

		// Assert
		var img = cut.Find("img");
		img.HasAttribute("style").ShouldBeTrue();
		img.GetAttribute("style").ShouldContain("background-color:Yellow");
	}

	[Fact]
	public void Image_WithHeight_RendersHeightInStyle()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" Height="Unit.Pixel(100)" />);

		// Assert
		var img = cut.Find("img");
		img.HasAttribute("style").ShouldBeTrue();
		img.GetAttribute("style").ShouldContain("height:100px");
	}

	[Fact]
	public void Image_WithWidth_RendersWidthInStyle()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" Width="Unit.Pixel(200)" />);

		// Assert
		var img = cut.Find("img");
		img.HasAttribute("style").ShouldBeTrue();
		img.GetAttribute("style").ShouldContain("width:200px");
	}

	[Fact]
	public void Image_WithMultipleStyles_CombinesCorrectly()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test"
			BackColor="Blue" ForeColor="White" Width="Unit.Pixel(150)" Height="Unit.Pixel(75)" />);

		// Assert
		var img = cut.Find("img");
		var style = img.GetAttribute("style");
		style.ShouldNotBeNull();
		style.ShouldContain("background-color:Blue");
		style.ShouldContain("color:White");
		style.ShouldContain("width:150px");
		style.ShouldContain("height:75px");
	}

	[Fact]
	public void Image_WithoutStyles_DoesNotRenderStyleAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" />);

		// Assert
		cut.Find("img").HasAttribute("style").ShouldBeFalse();
	}

	[Fact]
	public void Image_WithoutCssClass_DoesNotRenderClassAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" />);

		// Assert
		cut.Find("img").HasAttribute("class").ShouldBeFalse();
	}

	// =================================================================
	// Issue #18 — Image supports all BaseStyledComponent properties
	// =================================================================

	[Fact]
	public void Image_WithForeColor_RendersColorInStyle()
	{
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" ForeColor="Red" />);
		var img = cut.Find("img");
		img.HasAttribute("style").ShouldBeTrue();
		img.GetAttribute("style").ShouldContain("color:Red");
	}

	[Fact]
	public void Image_WithBorder_RendersAllBorderPropertiesInStyle()
	{
		// Border requires all three: BorderWidth > 0, BorderStyle != None/NotSet, BorderColor != default
		BlazorWebFormsComponents.Enums.BorderStyle solid = BlazorWebFormsComponents.Enums.BorderStyle.Solid;
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test"
			BorderWidth="Unit.Pixel(2)" BorderStyle="solid" BorderColor="Black" />);
		var img = cut.Find("img");
		img.HasAttribute("style").ShouldBeTrue();
		img.GetAttribute("style").ShouldContain("border:");
		img.GetAttribute("style").ShouldContain("2px");
		img.GetAttribute("style").ShouldContain("solid");
	}

	[Fact]
	public void Image_WithBorderWidthOnly_DoesNotRenderBorderStyle()
	{
		// Without BorderStyle and BorderColor, no border CSS should render
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Test" BorderWidth="Unit.Pixel(2)" />);
		var img = cut.Find("img");
		// Should not have style at all (border alone is insufficient)
		(img.HasAttribute("style") == false ||
		 !img.GetAttribute("style").Contains("border")).ShouldBeTrue();
	}

	[Fact]
	public void Image_AllStyleProperties_RenderCorrectly()
	{
		BlazorWebFormsComponents.Enums.BorderStyle solid = BlazorWebFormsComponents.Enums.BorderStyle.Solid;
		var cut = Render(@<Image ImageUrl="/img/test.png" AlternateText="Full styled image"
			CssClass="img-styled"
			BackColor="LightGray"
			ForeColor="DarkBlue"
			Width="Unit.Pixel(200)"
			Height="Unit.Pixel(150)"
			BorderWidth="Unit.Pixel(1)"
			BorderColor="Navy"
			BorderStyle="solid" />);

		var img = cut.Find("img");
		img.GetAttribute("class").ShouldBe("img-styled");
		var style = img.GetAttribute("style");
		style.ShouldContain("background-color:");
		style.ShouldContain("color:");
		style.ShouldContain("width:200px");
		style.ShouldContain("height:150px");
		style.ShouldContain("border:");
	}

}
