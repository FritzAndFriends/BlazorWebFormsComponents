
@code {

	// =================================================================
	// Issue #15 — AccessKey renders as accesskey="X" on various controls
	// =================================================================

	// --- Button AccessKey ---

	[Fact]
	public void Button_WithAccessKey_RendersAccessKeyAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Button Text="Click Me" AccessKey="B" />);

		// Assert
		var button = cut.Find("input[type=submit]");
		button.HasAttribute("accesskey").ShouldBeTrue();
		button.GetAttribute("accesskey").ShouldBe("B");
	}

	[Fact]
	public void Button_WithEmptyAccessKey_DoesNotRenderAccessKeyAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Button Text="Click Me" AccessKey="" />);

		// Assert
		cut.Find("input[type=submit]").HasAttribute("accesskey").ShouldBeFalse();
	}

	[Fact]
	public void Button_WithNullAccessKey_DoesNotRenderAccessKeyAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Button Text="Click Me" />);

		// Assert
		cut.Find("input[type=submit]").HasAttribute("accesskey").ShouldBeFalse();
	}

