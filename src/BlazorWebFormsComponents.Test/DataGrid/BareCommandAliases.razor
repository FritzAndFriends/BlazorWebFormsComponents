@code {

	// ─── P1-11: DataGrid bare command event aliases ─────────────────────
	// Verifies that ItemCommand, EditCommand, CancelCommand, UpdateCommand,
	// and DeleteCommand bare aliases are accepted as parameters.

	DataGridCommandEventArgs _itemCmdArgs;
	DataGridCommandEventArgs _editCmdArgs;
	DataGridCommandEventArgs _cancelCmdArgs;
	DataGridCommandEventArgs _updateCmdArgs;
	DataGridCommandEventArgs _deleteCmdArgs;

	#region ItemCommand

	[Fact]
	public void ItemCommand_BareAlias_ParameterAccepted()
	{
		_itemCmdArgs = null;
		var data = GetTestData();

		var cut = Render(
			@<DataGrid ItemType="DgCmdItem" Items="data" AutoGenerateColumns="false"
				ItemCommand="@((DataGridCommandEventArgs e) => _itemCmdArgs = e)">
				<Columns>
					<BoundField ItemType="DgCmdItem" DataField="Name" HeaderText="Name" />
				</Columns>
			</DataGrid>
		);

		cut.Instance.ShouldNotBeNull("DataGrid should accept bare ItemCommand parameter");
	}

	[Fact]
	public void OnItemCommand_Prefix_Also_Accepted()
	{
		var cut = Render(
			@<DataGrid ItemType="DgCmdItem" Items="GetTestData()" AutoGenerateColumns="false"
				OnItemCommand="@((DataGridCommandEventArgs e) => _itemCmdArgs = e)">
				<Columns>
					<BoundField ItemType="DgCmdItem" DataField="Name" HeaderText="Name" />
				</Columns>
			</DataGrid>
		);

		cut.Instance.ShouldNotBeNull();
	}

	#endregion

