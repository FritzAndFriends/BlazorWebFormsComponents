	private List<DgCmdItem> GetTestData()
	{
		return new List<DgCmdItem>
		{
			new DgCmdItem { Id = 1, Name = "Alpha" },
			new DgCmdItem { Id = 2, Name = "Beta" },
			new DgCmdItem { Id = 3, Name = "Gamma" }
