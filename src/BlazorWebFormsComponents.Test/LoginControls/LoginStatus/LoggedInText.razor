@using Moq;

@code {
	[Fact]
	public void LoginStatus_LoggedInText_DisplaysCustomLogoutText()
	{
		var authContext = this.AddAuthorization();
		authContext.SetAuthorized("James Bond");

		var navMock = new Mock<NavigationManager>();
		Services.AddSingleton<NavigationManager>(navMock.Object);

		var cut = Render(@<BlazorWebFormsComponents.LoginControls.LoginStatus LogoutText="Go Away!" />);

		cut.FindAll("input").Count().ShouldBe(0);
		cut.FindAll("a").Count().ShouldBe(1);

		cut.Find("a").FirstChild.TextContent.ShouldBe("Go Away!");
	}
}
