@using Moq;

@code {
	[Fact]
	public void LoginStatus_NotLoggedInEmpty_RendersNoElements()
	{
		var authContext = this.AddAuthorization();
		authContext.SetNotAuthorized();

		var navMock = new Mock<NavigationManager>();
		Services.AddSingleton<NavigationManager>(navMock.Object);

		var cut = Render(@<BlazorWebFormsComponents.LoginControls.LoginStatus LoginText="" LoginImageUrl="" />);

		cut.FindAll("input").Count().ShouldBe(0);
		cut.FindAll("a").Count().ShouldBe(0);
	}
}
