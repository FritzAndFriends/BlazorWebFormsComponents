@using Moq;
@using static BlazorWebFormsComponents.Enums.LogoutAction

@code {
	[Fact]
	public void LoginStatus_LogoutActionRedirect_NavigatesToLogoutPage()
	{
		var authContext = this.AddAuthorization();
		authContext.SetAuthorized("James Bond");

		var navigationManager = new MockNavigationManager();

		Services.AddSingleton<NavigationManager>(navigationManager);

		var cut = Render(@<BlazorWebFormsComponents.LoginControls.LoginStatus LogoutPageUrl="logout" LogoutAction="Redirect" />);

		cut.Find("a").Click();

		navigationManager.LastUri.ShouldBe("logout");
	}
}
