@using Moq;

@code {
	[Fact]
	public void LoginStatus_LogoutActionRefresh_DoesNotNavigate()
	{
		var authContext = this.AddAuthorization();
		authContext.SetAuthorized("James Bond");

		var navigationManager = new MockNavigationManager();

		Services.AddSingleton<NavigationManager>(navigationManager);

		var cut = Render(@<BlazorWebFormsComponents.LoginControls.LoginStatus LogoutPageUrl="logout" />);

		cut.Find("a").Click();

		navigationManager.LastUri.ShouldBe(null);
	}
}
