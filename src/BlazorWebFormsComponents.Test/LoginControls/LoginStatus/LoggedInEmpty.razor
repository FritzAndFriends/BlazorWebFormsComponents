@using Moq;

@code {
	[Fact]
	public void LoginStatus_LoggedInEmpty_RendersNoElements()
	{
		var authContext = this.AddAuthorization();
		authContext.SetAuthorized("James Bond");

		var navMock = new Mock<NavigationManager>();
		Services.AddSingleton<NavigationManager>(navMock.Object);

		var cut = Render(@<BlazorWebFormsComponents.LoginControls.LoginStatus LogoutText="" LogoutImageUrl="" />);

		cut.FindAll("input").Count().ShouldBe(0);
		cut.FindAll("a").Count().ShouldBe(0);
	}
}
