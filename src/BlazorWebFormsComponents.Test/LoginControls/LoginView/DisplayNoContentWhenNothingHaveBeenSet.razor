@using Moq;

@code {
	[Fact]
	public void LoginView_NoTemplates_RendersEmpty()
	{
		var authContext = this.AddAuthorization();
		authContext.SetNotAuthorized();

		var navMock = new Mock<NavigationManager>();
		Services.AddSingleton<NavigationManager>(navMock.Object);

		var cut = Render(@<BlazorWebFormsComponents.LoginControls.LoginView/>);

		cut.Markup.Trim().ShouldBeEmpty();
	}
}
