@code {

	[Fact]
	public void RadioButtonList_CausesValidation_DefaultIsTrue()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<RadioButtonList ItemType="object" StaticItems="items" />);

		cut.FindComponent<RadioButtonList<object>>().Instance.CausesValidation.ShouldBeTrue();
	}

	[Fact]
	public void RadioButtonList_CausesValidation_CanBeSetToFalse()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<RadioButtonList ItemType="object" StaticItems="items" CausesValidation="false" />);

		cut.FindComponent<RadioButtonList<object>>().Instance.CausesValidation.ShouldBeFalse();
	}

	[Fact]
	public void RadioButtonList_ValidationGroup_DefaultIsNull()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<RadioButtonList ItemType="object" StaticItems="items" />);

		cut.FindComponent<RadioButtonList<object>>().Instance.ValidationGroup.ShouldBeNull();
	}

	[Fact]
	public void RadioButtonList_ValidationGroup_AcceptsValue()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<RadioButtonList ItemType="object" StaticItems="items" ValidationGroup="AddressGroup" />);

		cut.FindComponent<RadioButtonList<object>>().Instance.ValidationGroup.ShouldBe("AddressGroup");
	}
}
