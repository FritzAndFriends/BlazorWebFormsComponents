	[Fact]
	public void Menu_IncludeStyleBlock_DefaultIsTrue()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;

		var cut = Render(
			@<Menu>
				<Items>
					<MenuItem Text="Home" Value="home" />
				</Items>
			</Menu>
		);

		cut.FindComponent<Menu>().Instance.IncludeStyleBlock.ShouldBeTrue();
	}

	[Fact]
	public void Menu_IncludeStyleBlock_CanBeSetToFalse()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;

		var cut = Render(
			@<Menu IncludeStyleBlock="false">
				<Items>
					<MenuItem Text="Home" Value="home" />
				</Items>
			</Menu>
		);

		cut.FindComponent<Menu>().Instance.IncludeStyleBlock.ShouldBeFalse();
	}
}
