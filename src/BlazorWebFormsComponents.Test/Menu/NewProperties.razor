@code {

	[Fact]
	public void Menu_ScrollDownText_DefaultIsNull()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;

		var cut = Render(
			@<Menu>
				<Items>
					<MenuItem Text="Home" Value="home" />
				</Items>
			</Menu>
		);

		cut.FindComponent<Menu>().Instance.ScrollDownText.ShouldBeNull();
	}

	[Fact]
	public void Menu_ScrollDownText_AcceptsValue()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;

		var cut = Render(
			@<Menu ScrollDownText="Scroll Down">
				<Items>
					<MenuItem Text="Home" Value="home" />
				</Items>
			</Menu>
		);

		cut.FindComponent<Menu>().Instance.ScrollDownText.ShouldBe("Scroll Down");
	}

