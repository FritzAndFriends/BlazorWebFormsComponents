@code {

	[Fact]
	public void CheckBoxList_CausesValidation_DefaultIsTrue()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<CheckBoxList ItemType="object" StaticItems="items" />);

		cut.FindComponent<CheckBoxList<object>>().Instance.CausesValidation.ShouldBeTrue();
	}

	[Fact]
	public void CheckBoxList_CausesValidation_CanBeSetToFalse()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<CheckBoxList ItemType="object" StaticItems="items" CausesValidation="false" />);

		cut.FindComponent<CheckBoxList<object>>().Instance.CausesValidation.ShouldBeFalse();
	}

	[Fact]
	public void CheckBoxList_ValidationGroup_DefaultIsNull()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<CheckBoxList ItemType="object" StaticItems="items" />);

		cut.FindComponent<CheckBoxList<object>>().Instance.ValidationGroup.ShouldBeNull();
	}

	[Fact]
	public void CheckBoxList_ValidationGroup_AcceptsValue()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<CheckBoxList ItemType="object" StaticItems="items" ValidationGroup="FormGroup" />);

		cut.FindComponent<CheckBoxList<object>>().Instance.ValidationGroup.ShouldBe("FormGroup");
	}
}
