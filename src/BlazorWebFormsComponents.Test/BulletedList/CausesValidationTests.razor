@code {

	[Fact]
	public void BulletedList_CausesValidation_DefaultIsTrue()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<BulletedList ItemType="object" StaticItems="items" />);

		cut.FindComponent<BulletedList<object>>().Instance.CausesValidation.ShouldBeTrue();
	}

	[Fact]
	public void BulletedList_CausesValidation_CanBeSetToFalse()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<BulletedList ItemType="object" StaticItems="items" CausesValidation="false" />);

		cut.FindComponent<BulletedList<object>>().Instance.CausesValidation.ShouldBeFalse();
	}

	[Fact]
	public void BulletedList_ValidationGroup_DefaultIsNull()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<BulletedList ItemType="object" StaticItems="items" />);

		cut.FindComponent<BulletedList<object>>().Instance.ValidationGroup.ShouldBeNull();
	}

	[Fact]
	public void BulletedList_ValidationGroup_AcceptsValue()
	{
		var items = new ListItemCollection
		{
			new ListItem("One", "1")
		};

		var cut = Render(@<BulletedList ItemType="object" StaticItems="items" ValidationGroup="ListGroup" />);

		cut.FindComponent<BulletedList<object>>().Instance.ValidationGroup.ShouldBe("ListGroup");
	}
}
