@using BlazorAjaxToolkitComponents
@using BlazorAjaxToolkitComponents.Enums

@code {

	private const string SLIDER_MODULE_PATH =
		"./_content/BlazorAjaxToolkitComponents/js/slider-extender.js";

	private void SetupLooseJs()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;
	}

	// === Rendering ===

	[Fact]
	public void RendersNoVisibleHTML()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.Markup.Trim().ShouldBeEmpty();
	}

	// === TargetControlID ===

	[Fact]
	public void TargetControlID_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="sliderInput" />);

		cut.FindComponent<SliderExtender>().Instance
			.TargetControlID.ShouldBe("sliderInput");
	}

	// === Minimum ===

	[Fact]
	public void Minimum_Default_Is0()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.Minimum.ShouldBe(0);
	}

	[Fact]
	public void Minimum_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<SliderExtender TargetControlID="slider1" Minimum="10" />
		);

		cut.FindComponent<SliderExtender>().Instance
			.Minimum.ShouldBe(10);
	}

	// === Maximum ===

	[Fact]
	public void Maximum_Default_Is100()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.Maximum.ShouldBe(100);
