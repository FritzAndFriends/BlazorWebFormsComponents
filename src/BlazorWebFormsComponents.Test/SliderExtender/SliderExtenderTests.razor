	public void HandleImageUrl_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<SliderExtender TargetControlID="slider1" HandleImageUrl="/images/handle.png" />
		);

		cut.FindComponent<SliderExtender>().Instance
			.HandleImageUrl.ShouldBe("/images/handle.png");
