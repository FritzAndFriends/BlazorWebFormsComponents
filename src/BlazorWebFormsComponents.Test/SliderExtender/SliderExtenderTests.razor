			.BoundControlID.ShouldBe("lblValue");
	}

	// === Orientation ===

	[Fact]
	public void Orientation_Default_IsHorizontal()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.Orientation.ShouldBe(SliderOrientation.Horizontal);
	}

