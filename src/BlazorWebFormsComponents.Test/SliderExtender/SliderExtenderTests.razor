	// === TooltipText ===

	[Fact]
	public void TooltipText_DefaultIsEmpty()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.TooltipText.ShouldBe(string.Empty);
	}

	[Fact]
	public void TooltipText_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<SliderExtender TargetControlID="slider1" TooltipText="Value: {0}" />
		);

		cut.FindComponent<SliderExtender>().Instance
			.TooltipText.ShouldBe("Value: {0}");
	}

	// === Enabled (inherited) ===

	[Fact]
	public void Enabled_DefaultsTrue()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.Enabled.ShouldBeTrue();
	}

	[Fact]
	public void Enabled_False_DoesNotInitializeJs()
	{
		SetupLooseJs();
		var cut = Render(
			@<SliderExtender TargetControlID="slider1" Enabled="false" />
		);

		cut.Markup.Trim().ShouldBeEmpty();
		JSInterop.Invocations["import"].ShouldBeEmpty();
	}

	// === JS Module Path ===

	[Fact]
	public void JsModulePath_MatchesExpectedPath()
	{
		SetupLooseJs();
		Render(@<SliderExtender TargetControlID="slider1" />);

		var importCalls = JSInterop.Invocations["import"];
		importCalls.ShouldNotBeEmpty();
		((string)importCalls[0].Arguments[0]).ShouldBe(SLIDER_MODULE_PATH);
	}

	// === Edge Cases ===

	[Fact]
	public void ThrowsWhenTargetControlIDEmpty()
	{
		SetupLooseJs();
		Should.Throw<InvalidOperationException>(() =>
		{
			Render(@<SliderExtender />);
		}).Message.ShouldContain("TargetControlID");
	}

	// === BehaviorID (inherited) ===

	[Fact]
	public void BehaviorID_DefaultsToNull()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.BehaviorID.ShouldBeNull();
	}
}
