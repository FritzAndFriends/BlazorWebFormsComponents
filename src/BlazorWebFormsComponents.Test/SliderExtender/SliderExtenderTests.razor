	public void Orientation_SetToVertical()
	{
		SetupLooseJs();
		var cut = Render(
			@<SliderExtender TargetControlID="slider1" Orientation="SliderOrientation.Vertical" />
		);

		cut.FindComponent<SliderExtender>().Instance
			.Orientation.ShouldBe(SliderOrientation.Vertical);
	}

	// === RailCssClass ===

	[Fact]
	public void RailCssClass_DefaultIsEmpty()
