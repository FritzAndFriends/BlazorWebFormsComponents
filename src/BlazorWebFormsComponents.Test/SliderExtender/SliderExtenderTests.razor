		);

		cut.FindComponent<SliderExtender>().Instance
			.Value.ShouldBe(50);
	}

	// === BoundControlID ===

	[Fact]
	public void BoundControlID_DefaultIsEmpty()
	{
		SetupLooseJs();
		var cut = Render(@<SliderExtender TargetControlID="slider1" />);

		cut.FindComponent<SliderExtender>().Instance
			.BoundControlID.ShouldBe(string.Empty);
	}

