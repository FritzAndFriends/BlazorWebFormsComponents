	public void Steps_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<SliderExtender TargetControlID="slider1" Steps="10" />
		);

		cut.FindComponent<SliderExtender>().Instance
			.Steps.ShouldBe(10);
	}

