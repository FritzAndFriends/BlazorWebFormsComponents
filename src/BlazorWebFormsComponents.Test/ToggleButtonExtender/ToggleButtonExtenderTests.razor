@using BlazorAjaxToolkitComponents
@using BlazorAjaxToolkitComponents.Enums

@code {

	private const string TOGGLE_MODULE_PATH =
		"./_content/BlazorAjaxToolkitComponents/js/toggle-button-extender.js";

	private void SetupLooseJs()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;
	}

	// === Rendering ===

	[Fact]
	public void RendersNoVisibleHTML()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.Markup.Trim().ShouldBeEmpty();
	}

	// === TargetControlID ===

	[Fact]
	public void TargetControlID_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chkAgree" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.TargetControlID.ShouldBe("chkAgree");
	}

	// === ImageWidth ===

	[Fact]
	public void ImageWidth_Default_IsZero()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.ImageWidth.ShouldBe(0);
	}

	[Fact]
	public void ImageWidth_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<ToggleButtonExtender TargetControlID="chk1" ImageWidth="32" />
		);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.ImageWidth.ShouldBe(32);
	}

	// === ImageHeight ===

	[Fact]
	public void ImageHeight_Default_IsZero()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
