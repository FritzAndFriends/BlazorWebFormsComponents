	// === Enabled (inherited) ===

	[Fact]
	public void Enabled_DefaultsTrue()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.Enabled.ShouldBeTrue();
	}

	[Fact]
	public void Enabled_False_DoesNotInitializeJs()
	{
		SetupLooseJs();
		var cut = Render(
			@<ToggleButtonExtender TargetControlID="chk1" Enabled="false" />
		);

		cut.Markup.Trim().ShouldBeEmpty();
		JSInterop.Invocations["import"].ShouldBeEmpty();
	}

	// === JS Module Path ===

	[Fact]
	public void JsModulePath_MatchesExpectedPath()
	{
		SetupLooseJs();
		Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		var importCalls = JSInterop.Invocations["import"];
		importCalls.ShouldNotBeEmpty();
		((string)importCalls[0].Arguments[0]).ShouldBe(TOGGLE_MODULE_PATH);
	}

	// === Edge Cases ===

	[Fact]
	public void ThrowsWhenTargetControlIDEmpty()
	{
		SetupLooseJs();
		Should.Throw<InvalidOperationException>(() =>
		{
			Render(@<ToggleButtonExtender />);
		}).Message.ShouldContain("TargetControlID");
	}

	// === BehaviorID (inherited) ===

	[Fact]
	public void BehaviorID_DefaultsToNull()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.BehaviorID.ShouldBeNull();
	}

	// === Full Configuration ===

	[Fact]
	public void AllParameters_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<ToggleButtonExtender
				TargetControlID="chkActive"
				ImageWidth="24"
				ImageHeight="24"
				UncheckedImageUrl="/img/off.png"
				CheckedImageUrl="/img/on.png"
				UncheckedImageAlternateText="Off"
				CheckedImageAlternateText="On"
				CheckedImageOverUrl="/img/on-hover.png"
				UncheckedImageOverUrl="/img/off-hover.png"
				DisabledUncheckedImageUrl="/img/off-dim.png"
				DisabledCheckedImageUrl="/img/on-dim.png" />
		);

		var instance = cut.FindComponent<ToggleButtonExtender>().Instance;
		instance.TargetControlID.ShouldBe("chkActive");
		instance.ImageWidth.ShouldBe(24);
		instance.ImageHeight.ShouldBe(24);
		instance.UncheckedImageUrl.ShouldBe("/img/off.png");
		instance.CheckedImageUrl.ShouldBe("/img/on.png");
		instance.UncheckedImageAlternateText.ShouldBe("Off");
		instance.CheckedImageAlternateText.ShouldBe("On");
		instance.CheckedImageOverUrl.ShouldBe("/img/on-hover.png");
		instance.UncheckedImageOverUrl.ShouldBe("/img/off-hover.png");
		instance.DisabledUncheckedImageUrl.ShouldBe("/img/off-dim.png");
		instance.DisabledCheckedImageUrl.ShouldBe("/img/on-dim.png");
	}
}
