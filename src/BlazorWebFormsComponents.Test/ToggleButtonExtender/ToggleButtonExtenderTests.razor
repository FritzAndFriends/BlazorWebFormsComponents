		cut.FindComponent<ToggleButtonExtender>().Instance
			.ImageHeight.ShouldBe(32);
	}

	// === UncheckedImageUrl ===

	[Fact]
	public void UncheckedImageUrl_DefaultIsEmpty()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.UncheckedImageUrl.ShouldBe(string.Empty);
	}

	[Fact]
	public void UncheckedImageUrl_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<ToggleButtonExtender TargetControlID="chk1" UncheckedImageUrl="/img/off.png" />
		);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.UncheckedImageUrl.ShouldBe("/img/off.png");
	}

	// === CheckedImageUrl ===

