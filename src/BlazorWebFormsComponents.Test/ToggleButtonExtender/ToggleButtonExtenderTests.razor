	// === Disabled images ===

	[Fact]
	public void DisabledUncheckedImageUrl_DefaultIsEmpty()
	{
		SetupLooseJs();
		var cut = Render(@<ToggleButtonExtender TargetControlID="chk1" />);

		cut.FindComponent<ToggleButtonExtender>().Instance
			.DisabledUncheckedImageUrl.ShouldBe(string.Empty);
