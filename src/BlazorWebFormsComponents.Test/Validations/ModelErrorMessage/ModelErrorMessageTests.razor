
@code {

	private ExampleModel exampleModel = new ExampleModel();

	[Fact]
	public void ModelErrorMessage_NoErrors_RendersNothing()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Name" CssClass="text-danger" />
			</EditForm>
		);

		cut.FindAll("span").Count.ShouldBe(0);
	}

	[Fact]
	public void ModelErrorMessage_SingleError_RendersSpanWithMessage()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Name" CssClass="text-danger" />
			</EditForm>
		);

		// Add an error to the EditContext
		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);
		messageStore.Add(editContext.Field("Name"), "Name is required.");
		editContext.NotifyValidationStateChanged();

		var span = cut.Find("span");
		span.TextContent.ShouldContain("Name is required.");
		span.GetAttribute("class").ShouldBe("text-danger");
	}

	[Fact]
	public void ModelErrorMessage_MultipleErrors_RendersWithBrSeparator()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Name" CssClass="text-danger" />
			</EditForm>
		);

		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);
		messageStore.Add(editContext.Field("Name"), "Name is required.");
		messageStore.Add(editContext.Field("Name"), "Name must be at least 3 characters.");
		editContext.NotifyValidationStateChanged();

		var span = cut.Find("span");
		span.InnerHtml.ShouldContain("Name is required.");
		span.InnerHtml.ShouldContain("<br>");
		span.InnerHtml.ShouldContain("Name must be at least 3 characters.");
	}

