	[Fact]
	public void ModelErrorMessage_HtmlEncodesMessages()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Name" CssClass="text-danger" />
			</EditForm>
		);

		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);
		messageStore.Add(editContext.Field("Name"), "<script>alert('xss')</script>");
		editContext.NotifyValidationStateChanged();

		var span = cut.Find("span");
		span.InnerHtml.ShouldNotContain("<script>");
		span.InnerHtml.ShouldContain("&lt;script&gt;");
	}

	[Fact]
	public void ModelErrorMessage_StripsBwfcValidatorMetadata()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Name" CssClass="text-danger" />
			</EditForm>
		);

		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);
		// BWFC validators encode as "Text,ErrorMessage\x1FValidationGroup"
		messageStore.Add(editContext.Field("Name"), "* Required,Name is required.\x1FGroup1");
		editContext.NotifyValidationStateChanged();

		var span = cut.Find("span");
		span.TextContent.ShouldBe("Name is required.");
		span.TextContent.ShouldNotContain("Group1");
		span.TextContent.ShouldNotContain("* Required");
	}

	public class ExampleModel
	{
		public string Name { get; set; }
		public string Email { get; set; }
		public string Password { get; set; }
	}
}
