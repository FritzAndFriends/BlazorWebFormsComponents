	[Fact]
	public void ModelErrorMessage_ErrorCleared_RendersNothing()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Name" CssClass="text-danger" />
			</EditForm>
		);

		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);

		// Add error
		messageStore.Add(editContext.Field("Name"), "Name is required.");
		editContext.NotifyValidationStateChanged();
		cut.Find("span").TextContent.ShouldContain("Name is required.");

		// Clear error
		messageStore.Clear();
		editContext.NotifyValidationStateChanged();
		cut.FindAll("span").Count.ShouldBe(0);
	}

	[Fact]
	public void ModelErrorMessage_SetFocusOnError_CallsJsInterop()
	{
		JSInterop.SetupVoid("bwfc.Validation.SetFocus", "password");

		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Password"
					AssociatedControlID="password"
					SetFocusOnError="true"
					CssClass="text-danger" />
			</EditForm>
		);

		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);
		messageStore.Add(editContext.Field("Password"), "Password too short.");
		editContext.NotifyValidationStateChanged();

		var invocation = JSInterop.VerifyInvoke("bwfc.Validation.SetFocus");
		invocation.Arguments[0].ShouldBe("password");
	}

	[Fact]
	public void ModelErrorMessage_SetFocusOnError_NoAssociatedControl_NoJsCall()
	{
		var cut = Render(
			@<EditForm Model="@exampleModel">
				<ModelErrorMessage ModelStateKey="Password"
					SetFocusOnError="true"
					CssClass="text-danger" />
			</EditForm>
		);

		var editForm = cut.FindComponent<EditForm>();
		var editContext = editForm.Instance.EditContext;
		var messageStore = new ValidationMessageStore(editContext);
		messageStore.Add(editContext.Field("Password"), "Password too short.");
		editContext.NotifyValidationStateChanged();

		JSInterop.VerifyNotInvoke("bwfc.Validation.SetFocus");
	}

