	// --- ExtractValuesFromCell ---

	[Fact]
	public void ExtractValuesFromCell_BoundField_PopulatesDictionary()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Product Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		var row = gridView.Rows[0];

		var values = new OrderedDictionary();
		var cell = row.Cells[0];

		cell.ContainingField.ExtractValuesFromCell(
			values, cell, DataControlRowState.Normal, includeReadOnly: true);

		values["Name"].ShouldBe("Widget");
	}

	[Fact]
	public void ExtractValuesFromCell_BoundField_SkipsReadOnlyWhenNotIncluded()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Product Name" ReadOnly="true" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		var row = gridView.Rows[0];

		var values = new OrderedDictionary();
		var cell = row.Cells[0];

		cell.ContainingField.ExtractValuesFromCell(
			values, cell, DataControlRowState.Normal, includeReadOnly: false);

		values.Count.ShouldBe(0);
	}

	// --- Non-generic GridViewRow shim delegation ---

	[Fact]
	public void NonGenericGridViewRow_FindControl_DelegatesToGeneric()
	{
		var formRowData = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["PurchaseQuantity"] = "5"
		};

		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="CartList"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<TemplateField ItemType="CompatProduct" HeaderText="Qty">
					<ItemTemplate>
						<TextBox ID="PurchaseQuantity" Text="1" />
					</ItemTemplate>
				</TemplateField>
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		var typedRow = gridView.Rows[0];
		typedRow.FormRowData = formRowData;

		// Convert to non-generic
		GridViewRow nonGenericRow = typedRow;

		// FindControl should still work through delegation
		var control = nonGenericRow.FindControl("PurchaseQuantity");
		control.ShouldNotBeNull();
		control.ShouldBeOfType<TextBox>();
		((TextBox)control).Text.ShouldBe("5");
	}

