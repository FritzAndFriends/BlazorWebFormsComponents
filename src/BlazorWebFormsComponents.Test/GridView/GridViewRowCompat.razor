@using Shouldly
@using System.Collections.Generic
@using System.Collections.Specialized

@inherits BlazorWebFormsTestContext

@code {

	// --- GridViewRowCollection typed indexer ---

	[Fact]
	public void Rows_Indexer_ReturnsGridViewRow_WithoutCast()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		gridView.Rows.Count.ShouldBe(1);

		// The key test: Rows[0] returns GridViewRow<T> directly, no cast needed
		GridViewRow<CompatProduct> row = gridView.Rows[0];
		row.ShouldNotBeNull();
		row.DataItem.ShouldNotBeNull();
		((CompatProduct)row.DataItem).Name.ShouldBe("Widget");
	}

	[Fact]
	public void Rows_Indexer_MultipleRows_AllReturnGridViewRow()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m },
			new CompatProduct { Name = "Gadget", Price = 19.99m },
			new CompatProduct { Name = "Doohickey", Price = 4.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		gridView.Rows.Count.ShouldBe(3);

		for (var i = 0; i < gridView.Rows.Count; i++)
		{
			GridViewRow<CompatProduct> row = gridView.Rows[i];
			row.ShouldNotBeNull();
		}
	}

	// --- Implicit operator: GridViewRow<T> -> GridViewRow (non-generic) ---

	[Fact]
	public void ImplicitOperator_GridViewRowGeneric_ConvertsToNonGeneric()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		var typedRow = gridView.Rows[0];

		// Implicit conversion: pass GridViewRow<T> to method accepting GridViewRow
		GridViewRow nonGenericRow = typedRow;
		nonGenericRow.ShouldNotBeNull();
		nonGenericRow.RowIndex.ShouldBe(typedRow.RowIndex);
		nonGenericRow.DataItemIndex.ShouldBe(typedRow.DataItemIndex);
		nonGenericRow.DataItem.ShouldBe(typedRow.DataItem);
	}

	[Fact]
	public void ImplicitOperator_HelperMethod_AcceptsGridViewRow()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;

		// This is the exact pattern from WingtipToys ShoppingCart:
		// Pass Rows[i] to a method that accepts non-generic GridViewRow
		var name = GetProductName(gridView.Rows[0]);
		name.ShouldBe("Widget");
	}

	// Helper mimicking the Web Forms pattern: GetValues(GridViewRow row)
	private static string GetProductName(GridViewRow row)
	{
		return ((CompatProduct)row.DataItem)?.Name;
	}

	// --- RowState property ---

	[Fact]
	public void RowState_Normal_ReturnsNormal()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		var row = gridView.Rows[0];

		row.RowState.ShouldBe(DataControlRowState.Normal);
	}

	[Fact]
	public void RowState_AlternateRow_HasAlternateFlag()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m },
			new CompatProduct { Name = "Gadget", Price = 19.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;

		// Row 0 is Normal
		gridView.Rows[0].RowState.ShouldBe(DataControlRowState.Normal);

		// Row 1 (odd index) should have Alternate flag
		(gridView.Rows[1].RowState & DataControlRowState.Alternate).ShouldBe(DataControlRowState.Alternate);
	}

	// --- Cells property ---

	[Fact]
	public void Cells_BoundField_ReturnsCellWithContainingField()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="CompatProduct" DataField="Name" HeaderText="Product Name" />
				<BoundField ItemType="CompatProduct" DataField="Price" HeaderText="Unit Price" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		var row = gridView.Rows[0];

		row.Cells.ShouldNotBeNull();
		row.Cells.Count.ShouldBe(2);

		row.Cells[0].ContainingField.ShouldNotBeNull();
		row.Cells[0].ContainingField.HeaderText.ShouldBe("Product Name");

		row.Cells[1].ContainingField.ShouldNotBeNull();
		row.Cells[1].ContainingField.HeaderText.ShouldBe("Unit Price");
	}

	[Fact]
	public void Cells_TemplateField_ReturnsCellWithTemplateField()
	{
		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="TestGrid"
