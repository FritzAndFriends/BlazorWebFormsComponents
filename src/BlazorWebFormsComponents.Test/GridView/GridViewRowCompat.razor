	// --- End-to-end: Exact WingtipToys ShoppingCart pattern ---

	[Fact]
	public void EndToEnd_WingtipToys_UpdateCartItems_Pattern()
	{
		// This test validates the EXACT code pattern from WingtipToys ShoppingCart.aspx.cs:
		//   for (int i = 0; i < CartList.Rows.Count; i++)
		//   {
		//       ... = GetValues(CartList.Rows[i]);
		//   }
		//   private ShoppingCartUpdates GetValues(GridViewRow row)
		//   {
		//       TextBox quantityTextBox = row.FindControl("PurchaseQuantity") as TextBox;
		//       ...
		//   }

		var formRowData0 = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["PurchaseQuantity"] = "3"
		};
		var formRowData1 = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["PurchaseQuantity"] = "7"
		};

		var data = new List<CompatProduct>
		{
			new CompatProduct { Name = "Widget", Price = 9.99m },
			new CompatProduct { Name = "Gadget", Price = 19.99m }
		};

		var cut = Render(@<GridView ItemType="CompatProduct" ID="CartList"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<TemplateField ItemType="CompatProduct" HeaderText="Qty">
					<ItemTemplate>
						<TextBox ID="PurchaseQuantity" Text="1" />
					</ItemTemplate>
				</TemplateField>
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<CompatProduct>>().Instance;
		gridView.Rows[0].FormRowData = formRowData0;
		gridView.Rows[1].FormRowData = formRowData1;

		// Simulate the exact WingtipToys loop pattern
		var quantities = new List<int>();
		for (var i = 0; i < gridView.Rows.Count; i++)
		{
			var qty = GetQuantity(gridView.Rows[i]);
			quantities.Add(qty);
		}

		quantities[0].ShouldBe(3);
		quantities[1].ShouldBe(7);
	}

	// Mimics the WingtipToys GetValues pattern:
	// private ShoppingCartUpdates GetValues(GridViewRow row)
	private static int GetQuantity(GridViewRow row)
	{
		var quantityTextBox = row.FindControl("PurchaseQuantity") as TextBox;
		if (quantityTextBox != null)
		{
			return Convert.ToInt32(quantityTextBox.Text);
		}
		return 0;
	}

	public class CompatProduct
	{
		public string Name { get; set; }
		public decimal Price { get; set; }
	}
}
