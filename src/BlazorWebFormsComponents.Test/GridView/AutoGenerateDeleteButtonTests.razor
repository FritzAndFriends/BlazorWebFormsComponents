@using BlazorWebFormsComponents.Enums

@code {

	[Fact]
	public void GridView_AutoGenerateDeleteButton_ParameterAccepted()
	{
		var data = GetTestItems();

		var cut = Render(@<GridView ItemType="DeleteTestItem" DataSource="data" AutoGenerateColumns="false"
						AutoGenerateDeleteButton="true">
			<Columns>
				<BoundField ItemType="DeleteTestItem" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<DeleteTestItem>>().Instance;
		gridView.AutoGenerateDeleteButton.ShouldBeTrue();
	}

	[Fact]
	public void GridView_AutoGenerateDeleteButton_DefaultIsFalse()
	{
		var data = GetTestItems();

		var cut = Render(@<GridView ItemType="DeleteTestItem" DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<BoundField ItemType="DeleteTestItem" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<DeleteTestItem>>().Instance;
		gridView.AutoGenerateDeleteButton.ShouldBeFalse();
	}

	[Fact]
	public void GridView_AutoGenerateDeleteButton_True_RendersDeleteLinkInRows()
	{
		var data = GetTestItems();

		var cut = Render(@<GridView ItemType="DeleteTestItem" DataSource="data" AutoGenerateColumns="false"
						AutoGenerateDeleteButton="true">
			<Columns>
				<BoundField ItemType="DeleteTestItem" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		// When AutoGenerateDeleteButton=true, each data row should contain a Delete link or button
		var bodyLinks = cut.FindAll("tbody a, tbody input[type=submit]");
		var deleteCount = bodyLinks.Count(el =>
			el.TextContent.Contains("Delete") ||
			(el.GetAttribute("value") ?? "").Contains("Delete"));
		deleteCount.ShouldBe(data.Count, "Each row should have a Delete link/button");
	}

	[Fact]
	public void GridView_AutoGenerateDeleteButton_False_NoDeleteLink()
	{
		var data = GetTestItems();

		var cut = Render(@<GridView ItemType="DeleteTestItem" DataSource="data" AutoGenerateColumns="false"
						AutoGenerateDeleteButton="false">
			<Columns>
				<BoundField ItemType="DeleteTestItem" DataField="Name" HeaderText="Name" />
			</Columns>
		</GridView>);

		var bodyLinks = cut.FindAll("tbody a, tbody input[type=submit]");
		var deleteCount = bodyLinks.Count(el =>
			el.TextContent.Contains("Delete") ||
			(el.GetAttribute("value") ?? "").Contains("Delete"));
		deleteCount.ShouldBe(0, "No Delete link/button should appear when AutoGenerateDeleteButton=false");
	}

	private List<DeleteTestItem> GetTestItems()
	{
		return new List<DeleteTestItem>
		{
			new DeleteTestItem { Id = 1, Name = "Alpha" },
			new DeleteTestItem { Id = 2, Name = "Beta" },
			new DeleteTestItem { Id = 3, Name = "Gamma" }
		};
	}

	public class DeleteTestItem
	{
		public int Id { get; set; }
		public string Name { get; set; }
	}
}
