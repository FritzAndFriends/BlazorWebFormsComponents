	[Fact]
	public void GridViewRow_FindControl_CastToTextBox_Works()
	{
		// This test validates the canonical WingtipToys ShoppingCart pattern:
		// TextBox qty = (TextBox)CartList.Rows[i].FindControl("PurchaseQuantity");
		// int quantity = Convert.ToInt16(qty.Text);
		var formRowData = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["PurchaseQuantity"] = "3"
		};

		var data = new List<FindControlProduct>
		{
			new FindControlProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="FindControlProduct" ID="CartList"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<TemplateField ItemType="FindControlProduct" HeaderText="Qty">
					<ItemTemplate>
						<TextBox ID="PurchaseQuantity" Text="1" />
					</ItemTemplate>
				</TemplateField>
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<FindControlProduct>>().Instance;
		var row = gridView.Rows[0] as GridViewRow<FindControlProduct>;
		row.ShouldNotBeNull();
		row.FormRowData = formRowData;

		// This is the exact pattern from ShoppingCart.aspx.cs:
		TextBox quantityTextBox = (TextBox)row.FindControl("PurchaseQuantity");
		int quantity = Convert.ToInt16(quantityTextBox.Text);
		quantity.ShouldBe(3);
	}

