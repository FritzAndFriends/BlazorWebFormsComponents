	[Fact]
	public void GridViewRow_FindControl_MultipleRows_IndependentData()
	{
		var data = new List<FindControlProduct>
		{
			new FindControlProduct { Name = "Widget", Price = 9.99m },
			new FindControlProduct { Name = "Gadget", Price = 19.99m }
		};

		var cut = Render(@<GridView ItemType="FindControlProduct" ID="CartList"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<TemplateField ItemType="FindControlProduct" HeaderText="Qty">
					<ItemTemplate>
						<TextBox ID="Qty" Text="1" />
					</ItemTemplate>
				</TemplateField>
				<TemplateField ItemType="FindControlProduct" HeaderText="Remove">
					<ItemTemplate>
						<CheckBox ID="Remove" />
					</ItemTemplate>
				</TemplateField>
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<FindControlProduct>>().Instance;

		// Row 0: Qty=5, Remove=on
		var row0 = gridView.Rows[0] as GridViewRow<FindControlProduct>;
		row0.ShouldNotBeNull();
		row0.FormRowData = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["Qty"] = "5",
			["Remove"] = "on"
		};

		// Row 1: Qty=2, Remove absent (unchecked)
		var row1 = gridView.Rows[1] as GridViewRow<FindControlProduct>;
		row1.ShouldNotBeNull();
		row1.FormRowData = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["Qty"] = "2"
		};

		// Verify row 0
		((TextBox)row0.FindControl("Qty")).Text.ShouldBe("5");
		((CheckBox)row0.FindControl("Remove")).Checked.ShouldBeTrue();

		// Verify row 1
		((TextBox)row1.FindControl("Qty")).Text.ShouldBe("2");
		((CheckBox)row1.FindControl("Remove")).Checked.ShouldBeFalse();
	}

	[Fact]
	public void GridViewRow_FindControl_CaseInsensitive()
	{
		var formRowData = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
		{
			["purchasequantity"] = "7"
		};

		var data = new List<FindControlProduct>
		{
			new FindControlProduct { Name = "Widget", Price = 9.99m }
		};

		var cut = Render(@<GridView ItemType="FindControlProduct" ID="CartList"
						DataSource="data" AutoGenerateColumns="false">
			<Columns>
				<TemplateField ItemType="FindControlProduct" HeaderText="Qty">
					<ItemTemplate>
						<TextBox ID="PurchaseQuantity" Text="1" />
					</ItemTemplate>
				</TemplateField>
			</Columns>
		</GridView>);

		var gridView = cut.FindComponent<GridView<FindControlProduct>>().Instance;
		var row = gridView.Rows[0] as GridViewRow<FindControlProduct>;
		row.ShouldNotBeNull();
		row.FormRowData = formRowData;

		// FindControl with different casing should still work
		var control = row.FindControl("PurchaseQuantity");
		control.ShouldNotBeNull();
		((TextBox)control).Text.ShouldBe("7");
	}

	public class FindControlProduct
	{
		public string Name { get; set; }
		public decimal Price { get; set; }
	}
