@code {

	[Fact]
	public void CheckBox_WithText_RendersInputAndLabel()
	{
		// Arrange & Act
		var cut = Render(@<CheckBox Text="Accept terms" />);

		// Assert
		cut.Find("input[type='checkbox']").ShouldNotBeNull();
		cut.Find("label").TextContent.ShouldBe("Accept terms");
	}

	[Fact]
	public void CheckBox_WithText_LabelHasForAttribute()
	{
		// Arrange & Act — use developer ID to verify label-input linkage
		var cut = Render(@<CheckBox ID="terms" Text="Accept terms" />);

		// Assert
		var input = cut.Find("input");
		var label = cut.Find("label");
		var inputId = input.GetAttribute("id");
		var labelFor = label.GetAttribute("for");

		inputId.ShouldBe("terms");
		labelFor.ShouldBe(inputId);
	}

}
