@inherits BlazorWebFormsTestContext

@code {
	[Fact]
	public void TreeView_CollapseImageToolTip_DefaultIsNull()
	{
		var cut = Render(
			@<TreeView>
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.CollapseImageToolTip.ShouldBeNull();
	}

	[Fact]
	public void TreeView_CollapseImageToolTip_CanBeSet()
	{
		var cut = Render(
			@<TreeView CollapseImageToolTip="Click to collapse">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.CollapseImageToolTip.ShouldBe("Click to collapse");
	}

	[Fact]
	public void TreeView_CollapseImageUrl_CanBeSet()
	{
		var cut = Render(
			@<TreeView CollapseImageUrl="/images/collapse.png">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.CollapseImageUrl.ShouldBe("/images/collapse.png");
	}

	[Fact]
	public void TreeView_ExpandImageToolTip_CanBeSet()
	{
		var cut = Render(
			@<TreeView ExpandImageToolTip="Click to expand">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.ExpandImageToolTip.ShouldBe("Click to expand");
	}

	[Fact]
	public void TreeView_ExpandImageUrl_CanBeSet()
	{
		var cut = Render(
			@<TreeView ExpandImageUrl="/images/expand.png">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.ExpandImageUrl.ShouldBe("/images/expand.png");
	}

	[Fact]
	public void TreeView_NoExpandImageUrl_CanBeSet()
	{
		var cut = Render(
			@<TreeView NoExpandImageUrl="/images/noexpand.png">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.NoExpandImageUrl.ShouldBe("/images/noexpand.png");
	}

	[Fact]
	public void TreeView_LineImagesFolder_CanBeSet()
	{
		var cut = Render(
			@<TreeView LineImagesFolder="/images/treelines/">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.LineImagesFolder.ShouldBe("/images/treelines/");
	}

	[Fact]
	public void TreeView_AutoGenerateDataBindings_DefaultIsFalse()
	{
		var cut = Render(
			@<TreeView>
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.AutoGenerateDataBindings.ShouldBeFalse();
	}

	[Fact]
	public void TreeView_MaxDataBindDepth_DefaultIsNegativeOne()
	{
		var cut = Render(
			@<TreeView>
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.MaxDataBindDepth.ShouldBe(-1);
	}

	[Fact]
	public void TreeView_MaxDataBindDepth_CanBeSet()
	{
		var cut = Render(
			@<TreeView MaxDataBindDepth="3">
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.MaxDataBindDepth.ShouldBe(3);
	}

	[Fact]
	public void TreeView_EnableClientScript_DefaultIsTrue()
	{
		var cut = Render(
			@<TreeView>
				<Nodes>
					<TreeNode Text="Root" Value="root" />
				</Nodes>
			</TreeView>
		);

		cut.FindComponent<TreeView>().Instance.EnableClientScript.ShouldBeTrue();
	}
}
