	[Fact]
	public void WebFormsForm_NoChildContent_RendersEmptyForm()
	{
		// Arrange & Act
		var cut = Render(
			@<WebFormsForm />
		);

		// Assert
		var form = cut.Find("form");
		form.ShouldNotBeNull();
		form.InnerHtml.Trim().ShouldBeEmpty();
	}

	[Fact]
	public void WebFormsForm_MethodPost_SetsFormMethodAttribute()
	{
		// Arrange & Act
		var cut = Render(
			@<WebFormsForm Method="FormMethod.Post">
				<input type="text" />
			</WebFormsForm>
		);

		// Assert
		var form = cut.Find("form");
		form.GetAttribute("method").ShouldBe("post");
	}

	[Fact]
	public void WebFormsForm_NestedElements_RendersCorrectly()
	{
		// Arrange & Act
		var cut = Render(
			@<WebFormsForm>
				<div class="form-group">
					<label>Name</label>
					<input type="text" name="name" />
				</div>
				<div class="form-group">
					<label>Email</label>
					<input type="email" name="email" />
				</div>
			</WebFormsForm>
		);

		// Assert
		var form = cut.Find("form");
		var groups = form.QuerySelectorAll("div.form-group");
		groups.Count().ShouldBe(2);
		var inputs = form.QuerySelectorAll("input");
		inputs.Count().ShouldBe(2);
	}

}
