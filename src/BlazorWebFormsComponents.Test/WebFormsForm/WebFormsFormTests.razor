	[Fact]
	public void WebFormsForm_MultipleHtmlAttributes_AllApplied()
	{
		// Arrange & Act
		var cut = Render(
			@<WebFormsForm id="regForm" class="styled" data-mode="edit">
				<input type="text" />
			</WebFormsForm>
		);

		// Assert
		var form = cut.Find("form");
		form.GetAttribute("id").ShouldBe("regForm");
		form.GetAttribute("class").ShouldBe("styled");
