
@code {

	[Fact]
	public void Button_WithToolTip_RendersTitleAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Button Text="Click Me!" ToolTip="Go To Bing!" OnClientClick="window.navigate('bing.com')" />);

		// Assert
		cut.MarkupMatches(@<input type="button" title="Go To Bing!" onclientclick="window.navigate('bing.com')" value="Click Me!" />);
	}

	[Fact]
	public void Button_WithoutToolTip_DoesNotRenderTitleAttribute()
	{
		// Arrange & Act
		var cut = Render(@<Button Text="Click Me!" OnClientClick="window.navigate('bing.com')" />);

		// Assert
		cut.MarkupMatches(@<input type="button" onclientclick="window.navigate('bing.com')" value="Click Me!" />);
	}

}
