@code {

	// ─── P0-2: DataList EventCallbacks ──────────────────────────────────
	// Verifies: ItemCommand, SelectedIndexChanged, EditCommand, UpdateCommand,
	//           DeleteCommand, CancelCommand, ItemCreated, ItemDataBound bare alias

	#region ItemDataBound bare alias (P2-5 included since audit says add it)

	[Fact]
	public void DataList_ItemDataBound_BareAlias_FiresPerItem()
	{
		var boundItems = new List<object>();
		var widgets = Widget.SimpleWidgetList.Take(3).ToArray();

		var cut = Render(
			@<DataList Items="widgets" ItemType="Widget" Context="Item"
				ItemDataBound="@((DataListItemEventArgs e) => boundItems.Add(e.Item))">
				<ItemTemplate><span>@Item.Name</span></ItemTemplate>
			</DataList>
		);

		// Must fire at least once per item (may fire more due to Blazor render cycle)
		boundItems.Count.ShouldBeGreaterThanOrEqualTo(3,
			"ItemDataBound (bare alias) should fire at least once per data item");
	}

	[Fact]
	public void DataList_OnItemDataBound_Existing_StillWorks()
	{
		var boundItems = new List<object>();
		var widgets = Widget.SimpleWidgetList.Take(3).ToArray();

		var cut = Render(
			@<DataList Items="widgets" ItemType="Widget" Context="Item"
				OnItemDataBound="@((DataListItemEventArgs e) => boundItems.Add(e.Item))">
				<ItemTemplate><span>@Item.Name</span></ItemTemplate>
			</DataList>
		);

		// Must fire at least once per item (Blazor may render twice)
		boundItems.Count.ShouldBeGreaterThanOrEqualTo(3,
			"OnItemDataBound should fire at least once per data item");
	}

	#endregion

