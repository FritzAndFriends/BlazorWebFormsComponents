	#region ItemCommand

	[Fact]
	public void DataList_ItemCommand_BareAlias_AcceptsCallback()
	{
		DataListCommandEventArgs capturedArgs = null;
		var widgets = Widget.SimpleWidgetList.Take(1).ToArray();

		var cut = Render(
			@<DataList Items="widgets" ItemType="Widget" Context="Item"
				ItemCommand="@((DataListCommandEventArgs e) => capturedArgs = e)">
				<ItemTemplate>
					<span>@Item.Name</span>
					<Button CommandName="Select" Text="Pick" />
				</ItemTemplate>
			</DataList>
		);

		cut.Find("input[type=submit]").Click();

		capturedArgs.ShouldNotBeNull("ItemCommand should fire on command button click");
		capturedArgs.CommandName.ShouldBe("Select");
	}

