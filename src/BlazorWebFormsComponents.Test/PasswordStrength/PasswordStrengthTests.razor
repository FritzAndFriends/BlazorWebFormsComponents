@using BlazorAjaxToolkitComponents
@using BlazorAjaxToolkitComponents.Enums

@code {

	private const string MODULE_PATH =
		"./_content/BlazorAjaxToolkitComponents/js/password-strength.js";

	/// <summary>
	/// Loose JS mode lets the extender's import/createBehavior/disposeBehavior
	/// calls succeed without explicit per-function setup.
	/// </summary>
	private void SetupLooseJs()
	{
		JSInterop.Mode = JSRuntimeMode.Loose;
	}

	// === Rendering ===

	[Fact]
	public void RendersNoVisibleHTML()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.Markup.Trim().ShouldBeEmpty();
	}

	// === DisplayPosition ===

	[Fact]
	public void DisplayPosition_DefaultIsRightSide()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.DisplayPosition.ShouldBe(DisplayPosition.RightSide);
	}

	[Fact]
	public void DisplayPosition_SetCorrectly()
	{
		DisplayPosition pos = DisplayPosition.BelowRight;
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" DisplayPosition="pos" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.DisplayPosition.ShouldBe(DisplayPosition.BelowRight);
	}

	// === StrengthIndicatorType ===

	[Fact]
	public void StrengthIndicatorType_DefaultIsText()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.StrengthIndicatorType.ShouldBe(StrengthIndicatorType.Text);
	}

	[Fact]
	public void StrengthIndicatorType_SetCorrectly()
	{
		StrengthIndicatorType type = StrengthIndicatorType.BarIndicator;
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" StrengthIndicatorType="type" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.StrengthIndicatorType.ShouldBe(StrengthIndicatorType.BarIndicator);
	}

	// === PreferredPasswordLength ===

	[Fact]
	public void PreferredPasswordLength_DefaultIs10()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.PreferredPasswordLength.ShouldBe(10);
	}

	[Fact]
	public void PreferredPasswordLength_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" PreferredPasswordLength="12" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.PreferredPasswordLength.ShouldBe(12);
	}

	// === MinimumNumericCharacters ===

	[Fact]
	public void MinimumNumericCharacters_DefaultIs0()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.MinimumNumericCharacters.ShouldBe(0);
	}

	[Fact]
	public void MinimumNumericCharacters_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" MinimumNumericCharacters="2" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.MinimumNumericCharacters.ShouldBe(2);
	}

	// === MinimumSymbolCharacters ===

	[Fact]
	public void MinimumSymbolCharacters_DefaultIs0()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.MinimumSymbolCharacters.ShouldBe(0);
	}

	[Fact]
	public void MinimumSymbolCharacters_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" MinimumSymbolCharacters="1" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.MinimumSymbolCharacters.ShouldBe(1);
	}

	// === RequiresUpperAndLowerCaseCharacters ===

	[Fact]
	public void RequiresUpperAndLowerCaseCharacters_DefaultIsFalse()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.RequiresUpperAndLowerCaseCharacters.ShouldBeFalse();
	}

	[Fact]
	public void RequiresUpperAndLowerCaseCharacters_SetCorrectly()
	{
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" RequiresUpperAndLowerCaseCharacters="true" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.RequiresUpperAndLowerCaseCharacters.ShouldBeTrue();
	}

	// === TextStrengthDescriptions ===

	[Fact]
	public void TextStrengthDescriptions_DefaultIsEmpty()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.TextStrengthDescriptions.ShouldBe(string.Empty);
	}

	[Fact]
	public void TextStrengthDescriptions_SetCorrectly()
	{
		string descriptions = "Very Poor;Weak;Average;Strong;Excellent";
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" TextStrengthDescriptions="@descriptions" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.TextStrengthDescriptions.ShouldBe("Very Poor;Weak;Average;Strong;Excellent");
	}

	// === StrengthStyles ===

	[Fact]
	public void StrengthStyles_DefaultIsEmpty()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.StrengthStyles.ShouldBe(string.Empty);
	}

	[Fact]
	public void StrengthStyles_SetCorrectly()
	{
		string styles = "poor;weak;avg;strong;excellent";
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" StrengthStyles="@styles" />
		);

		cut.FindComponent<PasswordStrength>().Instance
			.StrengthStyles.ShouldBe("poor;weak;avg;strong;excellent");
	}

	// === JS Module Path ===

	[Fact]
	public void JsModulePath_MatchesExpectedPath()
	{
		SetupLooseJs();
		Render(@<PasswordStrength TargetControlID="pwd1" />);

		var importCalls = JSInterop.Invocations["import"];
		importCalls.ShouldNotBeEmpty();
		((string)importCalls[0].Arguments[0]).ShouldBe(MODULE_PATH);
	}

	// === Edge Cases ===

	[Fact]
	public void ThrowsWhenTargetControlIDEmpty()
	{
		SetupLooseJs();
		Should.Throw<InvalidOperationException>(() =>
		{
			Render(@<PasswordStrength />);
		}).Message.ShouldContain("TargetControlID");
	}

	[Fact]
	public void Enabled_False_DoesNotInitializeJs()
	{
		SetupLooseJs();
		var cut = Render(
			@<PasswordStrength TargetControlID="pwd1" Enabled="false" />
		);

		cut.Markup.Trim().ShouldBeEmpty();
		JSInterop.Invocations["import"].ShouldBeEmpty();
	}

	[Fact]
	public void BehaviorID_DefaultsToNull()
	{
		SetupLooseJs();
		var cut = Render(@<PasswordStrength TargetControlID="pwd1" />);

		cut.FindComponent<PasswordStrength>().Instance
			.BehaviorID.ShouldBeNull();
	}
}
