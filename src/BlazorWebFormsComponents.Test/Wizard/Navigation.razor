	[Fact]
	public void Wizard_AllowReturnFalse_SkipsStepOnPrevious()
	{
		var cut = Render(
			@<Wizard ActiveStepIndex="2">
				<WizardSteps>
					<WizardStep Title="Step 1">
						<p>First Step Content</p>
					</WizardStep>
					<WizardStep Title="Step 2" AllowReturn="false">
						<p>Second Step Content</p>
					</WizardStep>
					<WizardStep Title="Step 3" StepType="WizardStepType.Finish">
						<p>Third Step Content</p>
					</WizardStep>
				</WizardSteps>
			</Wizard>
		);

		// Click Previous — should skip Step 2 (AllowReturn=false) and go to Step 1
		cut.Find("input[value='Previous']").Click();

		cut.Markup.ShouldContain("First Step Content");
		cut.Markup.ShouldNotContain("Second Step Content");
	}

