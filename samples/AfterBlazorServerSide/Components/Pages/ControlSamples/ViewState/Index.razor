@page "/ControlSamples/ViewState"
@using BlazorWebFormsComponents
@using BlazorWebFormsComponents.Enums

<PageTitle>ViewState &amp; PostBack Samples</PageTitle>

<h2>ViewState &amp; PostBack</h2>

<p>These samples demonstrate the <code>ViewStateDictionary</code> shim, <code>IsPostBack</code>,
   and <code>AutoPostBack</code> features. In Web Forms, these were core page lifecycle features.
   In BWFC, they work as migration compatibility shims — use them during migration, then
   graduate to native Blazor patterns.</p>

<hr />

<h3>1. Type-Safe ViewState (Interactive)</h3>
<p>Use <code>ViewState.Set&lt;T&gt;()</code> and <code>ViewState.GetValueOrDefault&lt;T&gt;()</code> for
   type-safe access. In Interactive Server mode, ViewState is kept in memory — no serialization overhead.</p>

<Panel @ref="_counterPanel" BorderStyle="BorderStyle.Solid" BorderWidth="Unit.Pixel(1)">
    <p>Click count: <strong>@_clickCount</strong></p>
    <button class="btn btn-primary" @onclick="IncrementCounter">Increment</button>
    <button class="btn btn-outline-secondary" @onclick="ResetCounter">Reset</button>
</Panel>

<p><strong>Code:</strong></p>
<pre><code>// Store with type safety
_counterPanel.ViewState.Set&lt;int&gt;("Count", _clickCount + 1);

// Retrieve with type safety — no casting needed
_clickCount = _counterPanel.ViewState.GetValueOrDefault&lt;int&gt;("Count");</code></pre>

<hr />

<h3>2. IsPostBack Detection</h3>
<p><code>IsPostBack</code> is mode-adaptive: in SSR it checks <code>HttpMethods.IsPost()</code>,
   in Interactive mode it tracks whether <code>OnInitialized</code> has run before.</p>

<Panel @ref="_postBackPanel" BorderStyle="BorderStyle.Solid" BorderWidth="Unit.Pixel(1)">
    <p>IsPostBack: <strong>@_isPostBack</strong></p>
    <p>Load count: <strong>@_loadCount</strong></p>
    <button class="btn btn-info" @onclick="SimulatePostBack">Simulate Interaction</button>
</Panel>

<p><strong>Code:</strong></p>
<pre><code>// In Web Forms:
if (!IsPostBack)
{
    BindGrid();  // Only on first load
}

// Same code works in BWFC — IsPostBack is false on first render,
// true on subsequent interactions</code></pre>

<hr />

<h3>3. Graduating Off ViewState</h3>
<p>ViewState is a <strong>migration shim, not a destination</strong>. Once your app runs in Blazor,
   refactor to native patterns — regular C# fields and properties.</p>

<div class="row">
    <div class="col-md-6">
        <h4>During Migration (ViewState)</h4>
        <pre><code>// Works, but indirect
ViewState.Set&lt;string&gt;("Filter", value);
var filter = ViewState.GetValueOrDefault&lt;string&gt;("Filter");</code></pre>
    </div>
    <div class="col-md-6">
        <h4>Native Blazor (Recommended)</h4>
        <pre><code>// Direct, type-safe, no overhead
private string Filter { get; set; } = "";

// Or as a parameter:
[Parameter]
public string Filter { get; set; } = "";</code></pre>
    </div>
</div>

<Panel BorderStyle="BorderStyle.Dashed" BorderWidth="Unit.Pixel(1)">
    <p>Filter value (native property): <strong>@_nativeFilter</strong></p>
    <input type="text" class="form-control" @bind="_nativeFilter" style="max-width:300px;" />
    <button class="btn btn-success mt-2" @onclick="ApplyNativeFilter">Apply</button>
    @if (!string.IsNullOrEmpty(_appliedFilter))
    {
        <p class="mt-2">Applied filter: <strong>@_appliedFilter</strong></p>
    }
</Panel>

@code {
    private Panel _counterPanel = default!;
    private Panel _postBackPanel = default!;

    private int _clickCount;
    private bool _isPostBack;
    private int _loadCount;
    private string _nativeFilter = "";
    private string _appliedFilter = "";

    protected override void OnInitialized()
    {
        _loadCount++;
    }

    private void IncrementCounter()
    {
        _counterPanel.ViewState.Set<int>("Count", _clickCount + 1);
        _clickCount = _counterPanel.ViewState.GetValueOrDefault<int>("Count");
    }

    private void ResetCounter()
    {
        _counterPanel.ViewState.Set<int>("Count", 0);
        _clickCount = 0;
    }

    private void SimulatePostBack()
    {
        _loadCount++;
        _isPostBack = true;
    }

    private void ApplyNativeFilter()
    {
        _appliedFilter = _nativeFilter;
    }
}
