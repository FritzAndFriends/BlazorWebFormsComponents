@page "/ControlSamples/CustomValidator"

<h3>Custom Validator</h3>
@using BlazorWebFormsComponents.Validations;

<div data-audit-control="CustomValidator-1">
<EditForm Model="@exampleModel" OnValidSubmit="@HandleValidSubmit">

	<label>Write something that starts with 'A'</label>
	<InputText id="name" @ref="Name.Current" @bind-Value="exampleModel.Name" />
	<CustomValidator ServerValidate="@DoesItStartWithA"
									 ControlRef="@Name"
									 Text="Does not start with 'A'."
									 ErrorMessage="Does not start with 'A' but in summary!" />

	<button type="submit">Submit</button>

</EditForm>
</div>

@code {
	ForwardRef<InputBase<string>> Name = new ForwardRef<InputBase<string>>();

	private ExampleModel exampleModel = new ExampleModel();

	private void HandleValidSubmit()
	{
		Console.WriteLine("OnValidSubmit");
	}

	private bool DoesItStartWithA(string value)
	{
		return value.StartsWith("A", StringComparison.InvariantCultureIgnoreCase);
	}

	public class ExampleModel
	{
		public string Name { get; set; }
	}
}

<hr />

<h3>ClientValidationFunction &amp; IsValid</h3>
<p>The <code>ClientValidationFunction</code> property is accepted for migration compatibility.
   In Web Forms it referenced a client-side JavaScript function — Blazor does not execute client scripts,
   so this is a migration stub. <code>IsValid</code> indicates whether the control passes validation.</p>

<div data-audit-control="CustomValidator-2">
<EditForm Model="@exampleModel2" OnValidSubmit="@HandleValidSubmit2">

	<label>Write something (IsValid starts true):</label>
	<InputText id="clientVal" @ref="ClientValRef.Current" @bind-Value="exampleModel2.Name" />
	<CustomValidator ServerValidate="@AlwaysValid"
					 ControlRef="@ClientValRef"
					 ClientValidationFunction="CheckValue"
					 IsValid="true"
					 Text="Validation failed."
					 ErrorMessage="Client validation failed!" />

	<button type="submit">Submit</button>

</EditForm>
</div>

@code {
	ForwardRef<InputBase<string>> ClientValRef = new ForwardRef<InputBase<string>>();

	private ExampleModel exampleModel2 = new ExampleModel();

	private void HandleValidSubmit2()
	{
		Console.WriteLine("ClientValidation: OnValidSubmit");
	}

	private bool AlwaysValid(string value) => true;
}

<hr />

<p>Code:</p>
<pre><code>&lt;CustomValidator ServerValidate="@@DoesItStartWithA" ControlRef="@@Name" Text="Does not start with 'A'." /&gt;

&lt;!-- Migration compatibility properties --&gt;
&lt;CustomValidator ServerValidate="@@AlwaysValid"
                 ControlRef="@@ClientValRef"
                 ClientValidationFunction="CheckValue"
                 IsValid="true"
                 Text="Validation failed." /&gt;</code></pre>
