@page "/ControlSamples/DataList"
@using static BlazorWebFormsComponents.WebColor

<h2>DataList Component homepage</h2>

<Nav />

<p>Here is a simple datalist bound to a collection of widgets.</p>

<div data-audit-control="DataList">
		<DataList @ref="simpleDataList"
							runat="server"
							EnableViewState="false"
							Context="Item"
							ItemType="SharedSampleObjects.Models.Widget">
            <HeaderTemplate>Simple Widgets</HeaderTemplate>
            <FooterTemplate>End of Line</FooterTemplate>
      <ItemStyleContent>
        <ItemStyle BackColor="Wheat" />
      </ItemStyleContent>
			<ItemTemplate>
                    @Item.Name - @Item.Price.ToString("c")
			</ItemTemplate>
		</DataList>
</div>

@code {

  BlazorWebFormsComponents.DataList<Widget> simpleDataList { get; set; }
  BlazorWebFormsComponents.DataList<Widget> keyDataList { get; set; }
  private int _editIndex = -1;

  protected override void OnAfterRender(bool firstRender)
  {

      if (firstRender)
      {
          simpleDataList.DataSource = Widget.SimpleWidgetList;
          simpleDataList.DataBind();
          keyDataList.DataSource = Widget.SimpleWidgetList;
          keyDataList.DataBind();
      }

      //base.OnParametersSet();
      base.OnAfterRender(firstRender);

  }

}

<hr />

<h3>DataKeyField &amp; EditItemIndex</h3>
<p>The <code>DataKeyField</code> property identifies the key field in the data source for item tracking.
   The <code>EditItemIndex</code> property specifies the zero-based index of the item in edit mode
   (-1 means no item is being edited). These properties are accepted for migration compatibility with
   Web Forms <code>&lt;asp:DataList DataKeyField="ID" EditItemIndex="0"&gt;</code>.</p>

<div data-audit-control="DataList-2">
		<DataList @ref="keyDataList"
							Context="Item"
							DataKeyField="Name"
							EditItemIndex="@_editIndex"
							ItemType="SharedSampleObjects.Models.Widget">
            <HeaderTemplate>Widgets (DataKeyField="Name", EditItemIndex=@_editIndex)</HeaderTemplate>
			<ItemTemplate>
                    @Item.Name - @Item.Price.ToString("c")
			</ItemTemplate>
		</DataList>
</div>

<p><em>DataKeyField: <code>Name</code> — EditItemIndex: <code>@_editIndex</code></em></p>

<pre><code>&lt;DataList DataKeyField="Name"
          EditItemIndex="-1"
          Context="Item"
          ItemType="Widget"&gt;
    &lt;ItemTemplate&gt;@@Item.Name - @@Item.Price.ToString("c")&lt;/ItemTemplate&gt;
&lt;/DataList&gt;</code></pre>

<p>Code:</p>
<code>
&lt;DataList Context="Item" ItemType="Widget"&gt;<br />
&nbsp;&nbsp;&lt;HeaderTemplate&gt;Simple Widgets&lt;/HeaderTemplate&gt;<br />
&nbsp;&nbsp;&lt;FooterTemplate&gt;End of Line&lt;/FooterTemplate&gt;<br />
&nbsp;&nbsp;&lt;ItemTemplate&gt;@@Item.Name - @@Item.Price.ToString("c")&lt;/ItemTemplate&gt;<br />
&lt;/DataList&gt;
</code>