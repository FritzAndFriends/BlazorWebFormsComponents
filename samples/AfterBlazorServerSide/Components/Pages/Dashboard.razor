@page "/dashboard"
@rendermode InteractiveServer
@using BlazorWebFormsComponents.Diagnostics
@inject ComponentHealthService HealthService

<PageTitle>Component Health Dashboard</PageTitle>

<div class="container-fluid py-3">

    @* ── Header area ── *@
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Component Health Dashboard</h1>
            <p class="text-muted mb-0">
                <strong>@filteredReports.Count</strong> components shown
                @if (filteredReports.Count != allReports.Count)
                {
                    <span> of @allReports.Count tracked</span>
                }
                &nbsp;│&nbsp;
                Average health: <strong class="@ScoreColorClass(averageHealth)">@averageHealth.ToString("F1")%</strong>
                &nbsp;│&nbsp;
                Generated: @DateTime.Now.ToString("yyyy-MM-dd")
            </p>
        </div>
    </div>

    @* ── Filters ── *@
    <div class="card mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <label class="form-label mb-0 fw-semibold small">Category</label>
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" @bind="selectedCategory">
                        <option value="">All Categories</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0 fw-semibold small">Status</label>
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" @bind="selectedStatus">
                        <option value="">All Statuses</option>
                        <option value="Complete">Complete</option>
                        <option value="Stub">Stub</option>
                        <option value="Deferred">Deferred</option>
                        <option value="NotStarted">Not Started</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0 fw-semibold small">Sort by</label>
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" @bind="sortField">
                        <option value="Score">Score (worst first)</option>
                        <option value="Name">Name</option>
                        <option value="Props">Property Parity</option>
                        <option value="Events">Event Parity</option>
                    </select>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showDeferred" @bind="showDeferred" />
                        <label class="form-check-label small" for="showDeferred">Show deferred</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Category tables ── *@
    @foreach (var group in groupedReports)
    {
        var categoryAvg = group.Value.Average(r => r.HealthScore);
        <div class="mb-4">
            <h4 class="d-flex align-items-center gap-2 mb-2">
                @group.Key
                <span class="badge bg-secondary">@group.Value.Count</span>
                <span class="badge @ScoreBadgeClass(categoryAvg)">Avg: @categoryAvg.ToString("F0")%</span>
            </h4>

            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Component</th>
                            <th class="text-center" style="width:80px">Score</th>
                            <th class="text-center" style="width:90px">Props</th>
                            <th class="text-center" style="width:90px">Events</th>
                            <th class="text-center" style="width:60px">Tests</th>
                            <th class="text-center" style="width:60px">Docs</th>
                            <th class="text-center" style="width:70px">Sample</th>
                            <th class="text-center" style="width:90px">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in group.Value)
                        {
                            <tr>
                                <td class="fw-medium">@report.Name</td>
                                <td class="text-center">
                                    <span class="badge @ScoreBadgeClass(report.HealthScore)">@report.HealthScore.ToString("F0")%</span>
                                </td>
                                <td class="text-center">@FormatFraction(report.ImplementedProperties, report.ExpectedProperties)</td>
                                <td class="text-center">@FormatFraction(report.ImplementedEvents, report.ExpectedEvents)</td>
                                <td class="text-center">@BoolIcon(report.HasTests)</td>
                                <td class="text-center">@BoolIcon(report.HasDocumentation)</td>
                                <td class="text-center">@BoolIcon(report.HasSamplePage)</td>
                                <td class="text-center"><span class="badge @StatusBadgeClass(report.Status)">@report.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!groupedReports.Any())
    {
        <div class="alert alert-info">No components match the current filters.</div>
    }

</div>

@code {
    private IReadOnlyList<ComponentHealthReport> allReports = Array.Empty<ComponentHealthReport>();
    private List<ComponentHealthReport> filteredReports = new();
    private Dictionary<string, List<ComponentHealthReport>> groupedReports = new();
    private List<string> categories = new();
    private double averageHealth;

    private string _selectedCategory = "";
    private string _selectedStatus = "";
    private string _sortField = "Score";
    private bool _showDeferred = false;

    private string selectedCategory
    {
        get => _selectedCategory;
        set { _selectedCategory = value; ApplyFilters(); }
    }

    private string selectedStatus
    {
        get => _selectedStatus;
        set { _selectedStatus = value; ApplyFilters(); }
    }

    private string sortField
    {
        get => _sortField;
        set { _sortField = value; ApplyFilters(); }
    }

    private bool showDeferred
    {
        get => _showDeferred;
        set { _showDeferred = value; ApplyFilters(); }
    }

    protected override void OnInitialized()
    {
        allReports = HealthService.GetAllReports();
        categories = allReports.Select(r => r.Category).Distinct().OrderBy(c => c).ToList();
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        IEnumerable<ComponentHealthReport> reports = allReports;

        // Hide deferred by default
        if (!_showDeferred)
        {
            reports = reports.Where(r => r.Status != ImplementationStatus.Deferred);
        }

        if (!string.IsNullOrEmpty(_selectedCategory))
        {
            reports = reports.Where(r => r.Category.Equals(_selectedCategory, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(_selectedStatus))
        {
            reports = reports.Where(r => r.Status.ToString().Equals(_selectedStatus, StringComparison.OrdinalIgnoreCase));
        }

        filteredReports = reports.ToList();
        averageHealth = filteredReports.Count > 0 ? filteredReports.Average(r => r.HealthScore) : 0;

        // Sort within each category (worst-first is the default)
        Comparison<ComponentHealthReport> comparison = _sortField switch
        {
            "Name" => (a, b) => string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase),
            "Props" => (a, b) => (a.PropertyParity ?? 2.0).CompareTo(b.PropertyParity ?? 2.0),
            "Events" => (a, b) => (a.EventParity ?? 2.0).CompareTo(b.EventParity ?? 2.0),
            _ => (a, b) => a.HealthScore.CompareTo(b.HealthScore) // Score ascending = worst first
        };

        groupedReports = filteredReports
            .GroupBy(r => r.Category)
            .OrderBy(g => g.Key)
            .ToDictionary(
                g => g.Key,
                g =>
                {
                    var list = g.ToList();
                    list.Sort(comparison);
                    return list;
                });
    }

    private static string FormatFraction(int implemented, int? expected)
    {
        if (!expected.HasValue)
            return "N/A";
        return $"{implemented}/{expected.Value}";
    }

    private static MarkupString BoolIcon(bool value)
    {
        return new MarkupString(value ? "✅" : "❌");
    }

    private static string ScoreColorClass(double score) => score switch
    {
        >= 90 => "text-success",
        >= 70 => "text-warning",
        _ => "text-danger"
    };

    private static string ScoreBadgeClass(double score) => score switch
    {
        >= 90 => "bg-success",
        >= 70 => "bg-warning text-dark",
        _ => "bg-danger"
    };

    private static string StatusBadgeClass(ImplementationStatus status) => status switch
    {
        ImplementationStatus.Complete => "bg-success",
        ImplementationStatus.Stub => "bg-warning text-dark",
        ImplementationStatus.Deferred => "bg-secondary",
        _ => "bg-danger"
    };
}
