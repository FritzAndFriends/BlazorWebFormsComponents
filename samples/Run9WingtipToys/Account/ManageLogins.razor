@page "/ManageLogins"
<h2>Manage your external logins.</h2>
    <PlaceHolder ID="successMessage" Visible="false">
            <p class="text-success"></p>
        </PlaceHolder>
    <div>
        <section id="externalLoginsForm">

            <ListView ItemType="object"
                DataKeyNames="LoginProvider,ProviderKey">
@* TODO: Replace SelectMethod="GetLogins" with Items="@_data" parameter on this BWFC data control. Load _data in OnInitializedAsync: _data = await yourDbContext.YourEntities.ToListAsync(); *@
@* TODO: ItemType="UserLoginInfo" was removed because the type is not available. Re-add when identity is wired up. *@

                <LayoutTemplate>
                    <h4>Registered Logins</h4>
                    <table class="table">
                        <tbody>
                            <tr id="itemPlaceholder"></tr>
                        </tbody>
                    </table>

                </LayoutTemplate>
                <ItemTemplate>
                    <tr>
                        <td>@context</td>
                        <td>
                            <Button Text="Remove" CommandName="Delete" CausesValidation="false"
                                ToolTip='@($"Remove this login from your account")'
                                CssClass="btn btn-default" />
                        </td>
                    </tr>
                </ItemTemplate>
            </ListView>

        </section>
    </div>
    <div>
        <OpenAuthProviders ReturnUrl="~/Account/ManageLogins" />
    </div>

