@page "/ManagePassword"
<h2>@(Title).</h2>
    <div class="form-horizontal">
        <section id="passwordForm">
            <PlaceHolder ID="setPassword" Visible="false">
                <p>
                    You do not have a local password for this site. Add a local
                        password so you can log in without an external login.
                </p>
                <div class="form-horizontal">
                    <h4>Set Password Form</h4>
                    <ValidationSummary ShowModelStateErrors="true" CssClass="text-danger" />
                    <hr />
                    <div class="form-group">
                        <Label AssociatedControlID="password" CssClass="col-md-2 control-label">Password</Label>
                        <div class="col-md-10">
                            <TextBox ID="password" TextMode="TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator Type="string" ControlToValidate="password"
                                CssClass="text-danger" ErrorMessage="The password field is required."
                                Display="ValidatorDisplay.Dynamic" ValidationGroup="SetPassword" />
                            <ModelErrorMessage ModelStateKey="NewPassword" AssociatedControlID="password"
                                CssClass="text-danger" SetFocusOnError="true" />
                        </div>
                    </div>

                    <div class="form-group">
                        <Label AssociatedControlID="confirmPassword" CssClass="col-md-2 control-label">Confirm password</Label>
                        <div class="col-md-10">
                            <TextBox ID="confirmPassword" TextMode="TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator Type="string" ControlToValidate="confirmPassword"
                                CssClass="text-danger" Display="ValidatorDisplay.Dynamic" ErrorMessage="The confirm password field is required."
                                ValidationGroup="SetPassword" />
                            <CompareValidator InputType="string" ControlToCompare="Password" ControlToValidate="confirmPassword"
                                CssClass="text-danger" Display="ValidatorDisplay.Dynamic" ErrorMessage="The password and confirmation password do not match."
                                ValidationGroup="SetPassword" />

                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <Button Text="Set Password" ValidationGroup="SetPassword" CssClass="btn btn-default" />
                        </div>
                    </div>
                </div>
            </PlaceHolder>

            <PlaceHolder ID="changePasswordHolder" Visible="false">
                <div class="form-horizontal">
                    <h4>Change Password Form</h4>
                    <hr />
                    <ValidationSummary ShowModelStateErrors="true" CssClass="text-danger" />
                    <div class="form-group">
                        <Label ID="CurrentPasswordLabel" AssociatedControlID="CurrentPassword" CssClass="col-md-2 control-label">Current password</Label>
                        <div class="col-md-10">
                            <TextBox ID="CurrentPassword" TextMode="TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator Type="string" ControlToValidate="CurrentPassword"
                                CssClass="text-danger" ErrorMessage="The current password field is required."
                                ValidationGroup="ChangePassword" />
                        </div>
                    </div>
                    <div class="form-group">
                        <Label ID="NewPasswordLabel" AssociatedControlID="NewPassword" CssClass="col-md-2 control-label">New password</Label>
                        <div class="col-md-10">
                            <TextBox ID="NewPassword" TextMode="TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator Type="string" ControlToValidate="NewPassword"
                                CssClass="text-danger" ErrorMessage="The new password is required."
                                ValidationGroup="ChangePassword" />
                        </div>
                    </div>
                    <div class="form-group">
                        <Label ID="ConfirmNewPasswordLabel" AssociatedControlID="ConfirmNewPassword" CssClass="col-md-2 control-label">Confirm new password</Label>
                        <div class="col-md-10">
                            <TextBox ID="ConfirmNewPassword" TextMode="TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator Type="string" ControlToValidate="ConfirmNewPassword"
                                CssClass="text-danger" Display="ValidatorDisplay.Dynamic" ErrorMessage="Confirm new password is required."
                                ValidationGroup="ChangePassword" />
                            <CompareValidator InputType="string" ControlToCompare="NewPassword" ControlToValidate="ConfirmNewPassword"
                                CssClass="text-danger" Display="ValidatorDisplay.Dynamic" ErrorMessage="The new password and confirmation password do not match."
                                ValidationGroup="ChangePassword" />
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <Button Text="Change Password" ValidationGroup="ChangePassword" CssClass="btn btn-default" />
                        </div>
                    </div>
                </div>
            </PlaceHolder>
        </section>
    </div>

