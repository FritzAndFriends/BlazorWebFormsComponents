@page "/Account/ManagePassword"
@rendermode InteractiveServer
@attribute [Authorize]

<h2>Manage Password.</h2>
<div class="form-horizontal">
    <h4>Change your password.</h4>
    <hr />
    <p class="text-danger">@errorMessage</p>
    <p class="text-success">@successMessage</p>
    <div class="form-group">
        <Label ID="CurrentPasswordLabel" Text="Current Password" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="CurrentPassword" CssClass="form-control" TextMode="@TextBoxMode.Password"
                     Text="@currentPassword" TextChanged="@(v => currentPassword = v)" />
        </div>
    </div>
    <div class="form-group">
        <Label ID="NewPasswordLabel" Text="New Password" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="NewPassword" CssClass="form-control" TextMode="@TextBoxMode.Password"
                     Text="@newPassword" TextChanged="@(v => newPassword = v)" />
        </div>
    </div>
    <div class="form-group">
        <Label ID="ConfirmLabel" Text="Confirm new password" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="ConfirmNewPassword" CssClass="form-control" TextMode="@TextBoxMode.Password"
                     Text="@confirmNewPassword" TextChanged="@(v => confirmNewPassword = v)" />
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <Button ID="SetPasswordBtn" Text="Change Password" CssClass="btn btn-default" OnClick="HandleChangePassword" />
        </div>
    </div>
</div>
