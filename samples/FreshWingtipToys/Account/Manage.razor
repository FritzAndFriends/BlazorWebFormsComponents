@page "/Manage"
<h2>@(Title).</h2>

    <div>
        <PlaceHolder ID="successMessage" Visible="false">
            <p class="text-success">@(SuccessMessage)</p>
        </PlaceHolder>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-horizontal">
                <h4>Change your account settings</h4>
                <hr />
                <dl class="dl-horizontal">
                    <dt>Password:</dt>
                    <dd>
                        <HyperLink NavigateUrl="/Account/ManagePassword" Text="[Change]" Visible="false" ID="ChangePassword" />
                        <HyperLink NavigateUrl="/Account/ManagePassword" Text="[Create]" Visible="false" ID="CreatePassword" />
                    </dd>
                    <dt>External Logins:</dt>
                    <dd>@(LoginsCount)
                        <HyperLink NavigateUrl="/Account/ManageLogins" Text="[Manage]" />

                    </dd>
                    @*
                        Phone Numbers can used as a second factor of verification in a two-factor authentication system.
                        See <a href="http://go.microsoft.com/fwlink/?LinkId=313242">this article</a>
                        for details on setting up this ASP.NET application to support two-factor authentication using SMS.
                        Uncomment the following block after you have set up two-factor authentication
                    *@

                    <dt>Phone Number:</dt>
                    @*
                    <% if (HasPhoneNumber)
                       { %>
                    <dd>
                        <HyperLink NavigateUrl="/Account/AddPhoneNumber" Text="[Add]" />
                    </dd>
                    <% }
                       else
                       { %>
                    <dd>
                        <Label Text="" ID="PhoneNumber" />
                        <HyperLink NavigateUrl="/Account/AddPhoneNumber" Text="[Change]" /> &nbsp;|&nbsp;
                        <LinkButton Text="[Remove]" OnClick="RemovePhone_Click" />
                    </dd>
                    <% } %>
                    *@

                    <dt>Two-Factor Authentication:</dt>
                    <dd>
                        <p>
                            There are no two-factor authentication providers configured. See <a href="http://go.microsoft.com/fwlink/?LinkId=313242">this article</a>
                            for details on setting up this ASP.NET application to support two-factor authentication.
                        </p>
                        <% if (TwoFactorEnabled)
                          { %> 
                        @*
                        Enabled
                        <LinkButton Text="[Disable]" CommandArgument="false" OnClick="TwoFactorDisable_Click" />
                        *@
                        <% }
                          else
                          { %> 
                        @*
                        Disabled
                        <LinkButton Text="[Enable]" CommandArgument="true" OnClick="TwoFactorEnable_Click" />
                        *@
                        <% } %>
                    </dd>
                </dl>
            </div>
        </div>
    </div>


