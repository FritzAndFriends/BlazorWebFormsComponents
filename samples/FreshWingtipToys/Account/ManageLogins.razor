@page "/ManageLogins"
<h2>Manage your external logins.</h2>
    <PlaceHolder ID="successMessage" Visible="false">
            <p class="text-success">@(SuccessMessage)</p>
        </PlaceHolder>
    <div>
        <section id="externalLoginsForm">

            <ListView
                TItem="UserLoginInfo"
                SelectMethod="GetLogins" DeleteMethod="RemoveLogin" DataKeyNames="LoginProvider,ProviderKey">

                <LayoutTemplate>
                    <h4>Registered Logins</h4>
                    <table class="table">
                        <tbody>
                            <tr id="itemPlaceholder"></tr>
                        </tbody>
                    </table>

                </LayoutTemplate>
                <ItemTemplate>
                    <tr>
                        <td>@context.LoginProvider</td>
                        <td>
                            <Button Text="Remove" CommandName="Delete" CausesValidation="false"
                                ToolTip='<%# "Remove this " + Item.LoginProvider + " login from your account" %>'
                                Visible="<%# CanRemoveExternalLogins %>" CssClass="btn btn-default" />
                        </td>
                    </tr>
                </ItemTemplate>
            </ListView>

        </section>
    </div>
    <div>
        <uc:OpenAuthProviders ReturnUrl="~/Account/ManageLogins" />
    </div>

