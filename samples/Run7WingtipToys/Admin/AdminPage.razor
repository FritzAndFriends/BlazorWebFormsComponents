@page "/AdminPage"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "canEdit")]

<h1>Administration</h1>
    <hr />
    <h3>Add Product:</h3>
    <table>
        <tr>
            <td><Label ID="LabelAddCategory">Category:</Label></td>
            <td>
                <DropDownList TItem="Category" Items="@categories"
                              DataTextField="CategoryName" DataValueField="CategoryID"
                              SelectedValue="@selectedCategoryId"
                              SelectedValueChanged="OnCategoryChanged"
                              CssClass="form-control" />
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddName">Name:</Label></td>
            <td>
                <TextBox ID="AddProductName" Text="@newProduct.ProductName" TextChanged="@(v => newProduct.ProductName = v)" />
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddDescription">Description:</Label></td>
            <td>
                <TextBox ID="AddProductDescription" Text="@(newProduct.Description ?? "")" TextChanged="@(v => newProduct.Description = v)" />
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddPrice">Price:</Label></td>
            <td>
                <TextBox ID="AddProductPrice" Text="@priceText" TextChanged="OnPriceChanged" />
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddImageFile">Image File:</Label></td>
            <td>
                <FileUpload @ref="fileUpload" Accept="image/*" MaxFileSize="5242880" />
            </td>
        </tr>
    </table>
    <p></p>
    <p></p>
    <Button ID="AddProductButton" Text="Add Product" CausesValidation="true" OnClick="AddProduct" />
    <Label ID="LabelAddStatus" Text="@addStatusMessage"></Label>
    <p></p>
    <h3>Remove Product:</h3>
    <table>
        <tr>
            <td><Label ID="LabelRemoveProduct">Product:</Label></td>
            <td>
                <DropDownList TItem="Product" Items="@products"
                              DataTextField="ProductName" DataValueField="ProductID"
                              SelectedValue="@selectedProductId"
                              SelectedValueChanged="OnProductChanged"
                              CssClass="form-control" />
            </td>
        </tr>
    </table>
    <p></p>
    <Button ID="RemoveProductButton" Text="Remove Product" CausesValidation="false" OnClick="RemoveProduct" />
    <Label ID="LabelRemoveStatus" Text="@removeStatusMessage"></Label>
