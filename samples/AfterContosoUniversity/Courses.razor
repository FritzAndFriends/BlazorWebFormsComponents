@page "/Courses"
<HeadContent>
    <link href="CSS/CSS_Courses.css" rel="stylesheet" />
    <script src="JQuery/JQuery_Courses.js"></script>
</HeadContent>
<div id="dropList">
    <h1 id="hdrCourse">Select Course</h1>
    <DropDownList ItemType="string" ID="drpDepartments"
        Items="@_departmentNames"
        SelectedValue="@_selectedDepartment"
        SelectedValueChanged="@((v) => _selectedDepartment = v)">
    </DropDownList>
    <Button ID="btnSearchCourse" Text="Search Courses" OnClick="HandleSearchByDepartment"></Button>
    <br />
    <br />
    <GridView ItemType="Cours" ID="grvCourses" AllowPaging="true" DataKeyNames="CourseID"
        PageSize="1" AutoGenerateColumns="false"
        Items="@_courses"
        EmptyDataText="Chose Department To Display Courses">
        <Columns>
            <BoundField ItemType="Cours" DataField="CourseID" HeaderText="ID" />
            <BoundField ItemType="Cours" DataField="CourseName" HeaderText="Course Name" />
            <BoundField ItemType="Cours" DataField="StudentsMax" HeaderText="Max Capacity" />
        </Columns>
    </GridView>
</div>
<div id="autoComplete">
    <h1 id="crsByName">Courses By Name</h1>
    <TextBox ID="txtCourse" Text="@_searchText" TextChanged="@((s) => _searchText = s)" placeholder="Search Course..."></TextBox>
    <Button ID="search" Text="Search" OnClick="HandleSearchByName"></Button>
    <br />
    <br />
    <DetailsView ItemType="Cours" ID="dtlCourses" Width="125" Height="50" CssClass="details"
        Items="@_searchResults">
    </DetailsView>
</div>

