@page "/Courses"
@inherits BlazorWebFormsComponents.WebFormsPageBase
<PageTitle>Contoso University - Courses</PageTitle>

<link href="CSS/CSS_Courses.css" rel="stylesheet" />

<div id="dropList">
    <h1 id="hdrCourse">Select Course</h1>
    <DropDownList ItemType="string" @ref="drpDepartments" DataSource="departments" />
    <br /><br />
    <GridView ItemType="ContosoUniversity.Models.Cours"
        @ref="grvCourses"
        AutoGenerateColumns="false"
        EmptyDataText="Choose Department To Display Courses">
        <Columns>
            <BoundField ItemType="ContosoUniversity.Models.Cours" DataField="CourseID" HeaderText="ID" />
            <BoundField ItemType="ContosoUniversity.Models.Cours" DataField="CourseName" HeaderText="Course Name" />
            <BoundField ItemType="ContosoUniversity.Models.Cours" DataField="Credits" HeaderText="Credits" />
        </Columns>
    </GridView>
</div>