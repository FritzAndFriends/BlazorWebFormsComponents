@page "/Courses"
<HeadContent>
    <link href="CSS/CSS_Courses.css" rel="stylesheet" />
</HeadContent>
<div id="dropList">
    <h1 id="hdrCourse">Select Course</h1>
    <select @bind="selectedDepartment">
        <option value="">-- Select Department --</option>
        @foreach (var dept in departments)
        {
            <option value="@dept">@dept</option>
        }
    </select>
    <Button Text="Search Courses" OnClick="@SearchCourses" />
    <br /><br />
    <GridView ItemType="Cours" AllowPaging="true" DataKeyNames="CourseID"
        PageSize="1" AutoGenerateColumns="false" SelectMethod="@GetCourseData"
        EmptyDataText="Chose Department To Display Courses">
        <Columns>
            <BoundField DataField="CourseID" HeaderText="ID" />
            <BoundField DataField="CourseName" HeaderText="Course Name" />
            <BoundField DataField="StudentsMax" HeaderText="Max Capacity" />
        </Columns>
    </GridView>
</div>
<div id="autoComplete">
    <h1 id="crsByName">Courses By Name</h1>
    <TextBox @bind-Text="courseSearchText" placeholder="Search Course..." />
    <Button Text="Search" OnClick="@SearchByName" />
    <br /><br />
    @if (selectedCourseDetail != null)
    {
        <DetailsView ItemType="Cours" AutoGenerateRows="true"
            DataItem="@selectedCourseDetail"
            Width="125" Height="50" CssClass="details" />
    }
</div>
