@page "/Courses"
<HeadContent>
    <link href="CSS/CSS_Courses.css" rel="stylesheet" />
    <script src="JQuery/JQuery_Courses.js"></script>
</HeadContent>
            <div id="dropList">
                <h1 id="hdrCourse">Select Course</h1>
                <DropDownList ItemType="object" ID="drpDepartments"></DropDownList>
                <Button ID="btnSearchCourse" Text="Search Courses" OnClick="@HandleSearchCourse"></Button>
                <br />
                <br />
                <GridView ItemType="object" ID="grvCourses" AllowPaging="true" DataKeyNames="CourseID"
                    PageSize="1" AutoGenerateColumns="false"
                    EmptyDataText="Chose Department To Display Courses">
                    <Columns>
                        <BoundField ItemType="object" DataField="CourseID" HeaderText="ID" />
                        <BoundField ItemType="object" DataField="CourseName" HeaderText="Course Name" />
                        <BoundField ItemType="object" DataField="StudentsMax" HeaderText="Max Capacity" />
                    </Columns>
                </GridView>
            </div>
            <div id="autoComplete">
                <h1 id="crsByName">Courses By Name</h1>
                <TextBox ID="txtCourse" placeholder="Search Course..."></TextBox>
                <Button ID="search" Text="Search" OnClick="@HandleCourseByName"></Button>
                <br />
                <br />
                @* TODO: ajaxToolkit:AutoCompleteExtender removed  implement client-side autocomplete *@
                <DetailsView ItemType="object" ID="dtlCourses" Width="125" Height="50" CssClass="details">
                </DetailsView>
            </div>