@page "/Students"
<HeadContent>
    <link href="CSS/Students_CSS.css" rel="stylesheet" />
</HeadContent>
<div id="grvStudentsData">
    <GridView ItemType="StudentListItem"
        CssClass="grv"
        AutoGenerateColumns="false"
        EmptyDataText="There are no records to display"
        SelectMethod="@GetStudentData"
        DataKeyNames="ID"
        BackColor="WebColor.White" BorderStyle="@("None")" BorderWidth="1"
        CellPadding="4" Height="336" Width="416">
        <Columns>
            <BoundField ItemType="StudentListItem" DataField="ID" HeaderText="Student ID" ReadOnly="true" />
            <BoundField ItemType="StudentListItem" DataField="FullName" HeaderText="Student Name" />
            <BoundField ItemType="StudentListItem" DataField="Email" HeaderText="Email" />
            <BoundField ItemType="StudentListItem" DataField="Date" HeaderText="Enrollment Date" ReadOnly="true" />
            <BoundField ItemType="StudentListItem" DataField="Count" HeaderText="Number of Courses" ReadOnly="true" />
        </Columns>
        <HeaderStyleContent>
            <GridViewHeaderStyle BackColor="WebColor.DarkBlue" Font_Bold="true" ForeColor="WebColor.LightBlue" />
        </HeaderStyleContent>
        <RowStyleContent>
            <GridViewRowStyle BackColor="WebColor.White" ForeColor="WebColor.DarkBlue" />
        </RowStyleContent>
    </GridView>
</div>
<div id="addStud">
    <h1 id="addStudent">Add Student</h1>
    <Table CssClass="tabAddStud" Font-Bold="true" ForeColor="WebColor.White">
        <TableRow>
            <TableCell>First Name</TableCell>
            <TableCell>
                <TextBox @bind-Text="firstName" placeholder="Type Your First Name..." />
            </TableCell>
        </TableRow>
        <TableRow>
            <TableCell>Last Name</TableCell>
            <TableCell>
                <TextBox @bind-Text="lastName" placeholder="Type Your Last Name..." />
            </TableCell>
        </TableRow>
        <TableRow>
            <TableCell>Birth Date</TableCell>
            <TableCell>
                <TextBox @bind-Text="birthDate" placeholder="dd.mm.year" />
            </TableCell>
        </TableRow>
        <TableRow>
            <TableCell>Email</TableCell>
            <TableCell>
                <TextBox @bind-Text="email" placeholder="Email is Optional..." />
            </TableCell>
        </TableRow>
        <TableRow>
            <TableCell>Course Name</TableCell>
            <TableCell>
                <select @bind="selectedCourse">
                    @foreach (var course in courseNames)
                    {
                        <option value="@course">@course</option>
                    }
                </select>
            </TableCell>
        </TableRow>
        <TableRow>
            <TableCell></TableCell>
            <TableCell>
                <Button CssClass="insert" Text="New Enrollment" OnClick="@InsertStudent" />
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                <Button Text="Clear" OnClick="@ClearForm" />
            </TableCell>
        </TableRow>
    </Table>
</div>
<div id="ajax">
    <h1 id="searchStud">Search Student</h1>
    <TextBox CssClass="txtSearch" @bind-Text="searchText" placeholder="Type Student Name..." />
    <Button Text="Show Student Info" OnClick="@SearchStudent" CssClass="btnInfo" />
    @if (searchResults != null && searchResults.Any())
    {
        <DetailsView ItemType="StudentInfo"
            DataItem="@searchResults.First()"
            Width="125" Height="50"
            AutoGenerateRows="false"
            CssClass="detailsView" BorderColor="WebColor.Black" ForeColor="WebColor.Black">
            <Fields>
                <BoundField ItemType="StudentInfo" DataField="FirstName" HeaderText="First Name" />
                <BoundField ItemType="StudentInfo" DataField="LastName" HeaderText="Last Name" />
                <BoundField ItemType="StudentInfo" DataField="Email" HeaderText="Email" />
                <BoundField ItemType="StudentInfo" DataField="BirthDate" HeaderText="Birth Date" />
                <BoundField ItemType="StudentInfo" DataField="StudentID" HeaderText="id" />
            </Fields>
        </DetailsView>
    }
</div>
