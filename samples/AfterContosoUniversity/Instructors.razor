@page "/Instructors"
@inherits BlazorWebFormsComponents.WebFormsPageBase
<PageTitle>Contoso University - Instructors</PageTitle>

<link href="CSS/Instructors_CSS.css" rel="stylesheet" />

<div id="grv">
    <h1 id="hdr">Our Instructors</h1>
    <GridView ItemType="ContosoUniversity.Models.Instructor" 
        @ref="grvInstructors"
        DataSource="instructorData"
        CssClass="grv" BorderWidth="2"
        AutoGenerateColumns="false"
        EmptyDataText="There are no records to display">
        <Columns>
            <BoundField ItemType="ContosoUniversity.Models.Instructor" DataField="InstructorID" HeaderText="Instructor ID" />
            <BoundField ItemType="ContosoUniversity.Models.Instructor" DataField="FirstName" HeaderText="First Name" />
            <BoundField ItemType="ContosoUniversity.Models.Instructor" DataField="LastName" HeaderText="Last Name" />
            <BoundField ItemType="ContosoUniversity.Models.Instructor" DataField="Email" HeaderText="Email" />
        </Columns>
    </GridView>
</div>