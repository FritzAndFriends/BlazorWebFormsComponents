@page "/AdminPage"
<h1>Administration</h1>
    <hr />
    <h3>Add Product:</h3>
    <table>
        <tr>
            <td><Label ID="LabelAddCategory">Category:</Label></td>
            <td>
                <DropDownList ID="DropDownAddCategory" 
                    TItem="Category" DataTextField="CategoryName" 
                    DataValueField="CategoryID" >
@* TODO: Replace SelectMethod="GetCategories" with Items="@_data" parameter on this BWFC data control. Load _data in OnInitializedAsync: _data = await yourDbContext.YourEntities.ToListAsync(); *@
                </DropDownList>
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddName">Name:</Label></td>
            <td>
                <TextBox ID="AddProductName"></TextBox>
                <RequiredFieldValidator Type="string" ID="RequiredFieldValidator1" Text="* Product name required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic"></RequiredFieldValidator>
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddDescription">Description:</Label></td>
            <td>
                <TextBox ID="AddProductDescription"></TextBox>
                <RequiredFieldValidator Type="string" ID="RequiredFieldValidator2" Text="* Description required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic"></RequiredFieldValidator>
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddPrice">Price:</Label></td>
            <td>
                <TextBox ID="AddProductPrice"></TextBox>
                <RequiredFieldValidator Type="string" ID="RequiredFieldValidator3" Text="* Price required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic"></RequiredFieldValidator>
                <RegularExpressionValidator Type="string" ID="RegularExpressionValidator1" Text="* Must be a valid price without $." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic" ValidationExpression="^[0-9]*(\.)?[0-9]?[0-9]?$"></RegularExpressionValidator>
            </td>
        </tr>
        <tr>
            <td><Label ID="LabelAddImageFile">Image File:</Label></td>
            <td>
                <FileUpload ID="ProductImage" />
                <RequiredFieldValidator Type="string" ID="RequiredFieldValidator4" Text="* Image path required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic"></RequiredFieldValidator>
            </td>
        </tr>
    </table>
    <p></p>
    <p></p>
    <Button ID="AddProductButton" Text="Add Product" OnClick="OnAddProduct"  CausesValidation="true"/>
    <Label ID="LabelAddStatus" Text=""></Label>
    <p></p>
    <h3>Remove Product:</h3>
    <table>
        <tr>
            <td><Label ID="LabelRemoveProduct">Product:</Label></td>
            <td><DropDownList ID="DropDownRemoveProduct" TItem="Product" AppendDataBoundItems="true" 
                    DataTextField="ProductName" DataValueField="ProductID" >
@* TODO: Replace SelectMethod="GetProducts" with Items="@_data" parameter on this BWFC data control. Load _data in OnInitializedAsync: _data = await yourDbContext.YourEntities.ToListAsync(); *@
                </DropDownList>
            </td>
        </tr>
    </table>
    <p></p>
    <Button ID="RemoveProductButton" Text="Remove Product" OnClick="OnRemoveProduct" CausesValidation="false"/>
    <Label ID="LabelRemoveStatus" Text=""></Label>

