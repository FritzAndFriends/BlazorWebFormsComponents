@page "/AddToCart"
@using WingtipToys.Logic
@inject ShoppingCartActions ShoppingCartActions
@inject NavigationManager Navigation

@code {
    [SupplyParameterFromQuery(Name = "productID")]
    public int ProductID { get; set; }

    protected override void OnInitialized()
    {
        if (ProductID > 0)
        {
            ShoppingCartActions.AddToCart(ProductID);
        }
        Navigation.NavigateTo("/ShoppingCart", replace: true);
    }
}
