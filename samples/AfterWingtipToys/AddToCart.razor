@page "/AddToCart"
@inject CartStore CartStore

<PageTitle>Add To Cart</PageTitle>
<p>Adding item to cart...</p>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "productID")]
    public int? ProductId { get; set; }

    protected override void OnInitialized()
    {
        var cartId = Session[CartSessionKey]?.ToString();
        if (string.IsNullOrWhiteSpace(cartId))
        {
            cartId = Guid.NewGuid().ToString("N");
            Session[CartSessionKey] = cartId;
        }

        if (ProductId.HasValue)
        {
            CartStore.AddItem(cartId!, ProductId.Value);
        }

        Response.Redirect("~/ShoppingCart.aspx");
    }

    private const string CartSessionKey = "CartId";
}
