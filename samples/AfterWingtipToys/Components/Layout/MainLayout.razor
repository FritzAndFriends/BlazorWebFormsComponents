@inherits LayoutComponentBase
@inject ProductContext Db

<HeadContent>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wingtip Toys</title>
    <link href="/favicon.ico" rel="shortcut icon" type="image/x-icon" />
</HeadContent>

<div class="navbar navbar-inverse navbar-fixed-top">
    <div class="container">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <a class="navbar-brand" href="/">Wingtip Toys</a>
        </div>
        <div class="navbar-collapse collapse">
            <ul class="nav navbar-nav">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Contact</a></li>
                <li><a href="/ProductList">Products</a></li>
                <li><a href="/ShoppingCart" id="cartCount">&nbsp;</a></li>
            </ul>
            <AuthorizeView>
                <NotAuthorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Register">Register</a></li>
                        <li><a href="/Account/Login">Log in</a></li>
                    </ul>
                </NotAuthorized>
                <Authorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Manage" title="Manage your account">Hello, @context.User.Identity?.Name !</a></li>
                        <li><a href="/Account/Login">Log off</a></li>
                    </ul>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>
<div id="TitleContent" style="text-align: center">
    <a href="/">
        <img id="Image1" src="/Images/logo.jpg" style="border-style:none" alt="Logo" />
    </a>
    <br />
</div>
<div id="CategoryMenu" style="text-align: center">
    @if (_categories != null)
    {
        @for (int i = 0; i < _categories.Count; i++)
        {
            var cat = _categories[i];
            <b style="font-size: large; font-style: normal">
                <a href="@($"/ProductList?categoryName={cat.CategoryName}")">@cat.CategoryName</a>
            </b>
            @if (i < _categories.Count - 1)
            {
                <text>  |  </text>
            }
        }
    }
</div>
<div class="container body-content">
    @Body
    <hr />
    <footer>
        <p>&copy; @(DateTime.Now.Year) - Wingtip Toys</p>
    </footer>
</div>

@code {
    private List<Category>? _categories;

    protected override void OnInitialized()
    {
        _categories = Db.Categories.OrderBy(c => c.CategoryID).ToList();
    }
}
