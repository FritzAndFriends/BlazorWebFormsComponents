@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject WingtipToys.Services.CategoryNavigationService CategoryNavigationService

<div class="navbar navbar-inverse navbar-static-top">
    <div class="container" style="min-height: 64px;">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#main-navbar">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <a class="navbar-brand" href="/">Wingtip Toys</a>
        </div>
        <div id="main-navbar" class="navbar-collapse collapse">
            <ul class="nav navbar-nav">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Contact</a></li>
                <li><a href="/ProductList">Products</a></li>
                <li><a href="/ShoppingCart">Cart</a></li>
            </ul>
            <AuthorizeView>
                <Authorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Manage">Hello, @context.User.Identity?.Name!</a></li>
                        <li><a href="/Account/Logout" data-enhance-nav="false">Log out</a></li>
                    </ul>
                </Authorized>
                <NotAuthorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Register">Register</a></li>
                        <li><a href="/Account/Login">Log in</a></li>
                    </ul>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

<div class="container body-content">
    <div id="TitleContent" class="text-center">
        <a href="/"><img src="/Images/logo.jpg" alt="Wingtip Toys" class="img-responsive center-block" style="margin: 0 auto;" /></a>
        <br />
    </div>

    <div class="row">
        <aside class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-heading"><strong>Categories</strong></div>
                <ul class="list-group">
                    @foreach (var category in Categories)
                    {
                        <li class="list-group-item">
                            <a href="@($"/Category/{Uri.EscapeDataString(category.CategoryName)}")">@category.CategoryName</a>
                        </li>
                    }
                </ul>
            </div>
        </aside>
        <div class="col-md-9">
            <main role="main" style="min-height: 320px;">
                @Body
            </main>
        </div>
    </div>

    <hr />
    <footer>
        <p>&copy; 2013 - Wingtip Toys</p>
    </footer>
</div>

@code {
    private IReadOnlyList<Category> Categories { get; set; } = Array.Empty<Category>();

    protected override async Task OnInitializedAsync()
    {
        Categories = await CategoryNavigationService.GetCategoriesAsync();
    }
}
