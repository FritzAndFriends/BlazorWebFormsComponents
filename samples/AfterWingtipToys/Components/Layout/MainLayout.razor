@inherits LayoutComponentBase
@inject WingtipToys.Logic.CatalogService CatalogService
@inject WingtipToys.Logic.ShoppingCartService ShoppingCartService

<div class="navbar navbar-inverse navbar-static-top">
    <div class="container-fluid">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <a class="navbar-brand" href="/">Wingtip Toys</a>
        </div>
        <div class="navbar-collapse collapse">
            <ul class="nav navbar-nav">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Contact</a></li>
                <li><a href="/ProductList">Products</a></li>
                <li><a href="/ShoppingCart">Cart (@CartCount)</a></li>
            </ul>
            <AuthorizeView>
                <Authorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Manage">Hello, @context.User.Identity?.Name</a></li>
                        <li><a href="/Account/Logout" data-enhance-nav="false">Log out</a></li>
                    </ul>
                </Authorized>
                <NotAuthorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Register">Register</a></li>
                        <li><a href="/Account/Login">Log in</a></li>
                    </ul>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

<div id="TitleContent" class="text-center">
    <a href="/">
        <img src="/Images/logo.jpg" alt="Wingtip Toys" />
    </a>
    <br />
</div>

<div class="container-fluid body-content">
    <div class="row">
        <aside class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <strong>Categories</strong>
                </div>
                <div class="list-group">
                    @foreach (var category in Categories)
                    {
                        <a class="list-group-item" href="/ProductList?id=@category.CategoryID">@category.CategoryName</a>
                    }
                </div>
            </div>
        </aside>
        <div class="col-md-9">
            <main role="main">
                @Body
            </main>
        </div>
    </div>
    <hr />
    <footer>
        <p>&copy; 2013 - Wingtip Toys</p>
    </footer>
</div>

@code {
    private IReadOnlyList<Category> Categories { get; set; } = Array.Empty<Category>();

    private int CartCount { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Categories = await CatalogService.GetCategoriesAsync();
        CartCount = await ShoppingCartService.GetCountAsync();
    }
}
