@page "/Account/Forgot"
<h2>Forgot Password</h2>

    <div class="row">
        <div class="col-md-8">
            <div class="form-horizontal">
                <h4>Forgot your password?</h4>
                <hr />
                <div class="form-group">
                    <Label CssClass="col-md-2 control-label">Email</Label>
                    <div class="col-md-10">
                        <TextBox CssClass="form-control" TextMode="TextBoxMode.Email" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-offset-2 col-md-10">
                        <Button Text="Submit" CssClass="btn btn-default" />
                    </div>
                </div>
            </div>
        </div>
    </div>

