@page "/ManagePassword"
<PageTitle>Manage Password</PageTitle>
    <h2>@(Title).</h2>
    <div class="form-horizontal">
        <section id="passwordForm">
            <PlaceHolder id="setPassword" @ref="setPassword" Visible="false">
                <p>
                    You do not have a local password for this site. Add a local
                        password so you can log in without an external login.
                </p>
                <div class="form-horizontal">
                    <h4>Set Password Form</h4>
                    <ValidationSummary ShowModelStateErrors="true" CssClass="text-danger" />
                    <hr />
                    <div class="form-group">
                        <Label AssociatedControlID="password" CssClass="col-md-2 control-label">Password</Label>
                        <div class="col-md-10">
                            <TextBox id="password" @ref="password" TextMode="@TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator ControlToValidate="password"
                                CssClass="text-danger" ErrorMessage="The password field is required."
                                Display="Dynamic" ValidationGroup="SetPassword" />
                            <ModelErrorMessage ModelStateKey="NewPassword" AssociatedControlID="password"
                                CssClass="text-danger" SetFocusOnError="true" />
                        </div>
                    </div>

                    <div class="form-group">
                        <Label AssociatedControlID="confirmPassword" CssClass="col-md-2 control-label">Confirm password</Label>
                        <div class="col-md-10">
                            <TextBox id="confirmPassword" @ref="confirmPassword" TextMode="@TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator ControlToValidate="confirmPassword"
                                CssClass="text-danger" Display="Dynamic" ErrorMessage="The confirm password field is required."
                                ValidationGroup="SetPassword" />
                            <CompareValidator ControlToCompare="Password" ControlToValidate="confirmPassword"
                                CssClass="text-danger" Display="Dynamic" ErrorMessage="The password and confirmation password do not match."
                                ValidationGroup="SetPassword" />

                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <Button Text="Set Password" ValidationGroup="SetPassword" OnClick="@SetPassword_Click" CssClass="btn btn-default" />
                        </div>
                    </div>
                </div>
            </PlaceHolder>

            <PlaceHolder id="changePasswordHolder" @ref="changePasswordHolder" Visible="false">
                <div class="form-horizontal">
                    <h4>Change Password Form</h4>
                    <hr />
                    <ValidationSummary ShowModelStateErrors="true" CssClass="text-danger" />
                    <div class="form-group">
                        <Label id="CurrentPasswordLabel" @ref="CurrentPasswordLabel" AssociatedControlID="CurrentPassword" CssClass="col-md-2 control-label">Current password</Label>
                        <div class="col-md-10">
                            <TextBox id="CurrentPassword" @ref="CurrentPassword" TextMode="@TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator ControlToValidate="CurrentPassword"
                                CssClass="text-danger" ErrorMessage="The current password field is required."
                                ValidationGroup="ChangePassword" />
                        </div>
                    </div>
                    <div class="form-group">
                        <Label id="NewPasswordLabel" @ref="NewPasswordLabel" AssociatedControlID="NewPassword" CssClass="col-md-2 control-label">New password</Label>
                        <div class="col-md-10">
                            <TextBox id="NewPassword" @ref="NewPassword" TextMode="@TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator ControlToValidate="NewPassword"
                                CssClass="text-danger" ErrorMessage="The new password is required."
                                ValidationGroup="ChangePassword" />
                        </div>
                    </div>
                    <div class="form-group">
                        <Label id="ConfirmNewPasswordLabel" @ref="ConfirmNewPasswordLabel" AssociatedControlID="ConfirmNewPassword" CssClass="col-md-2 control-label">Confirm new password</Label>
                        <div class="col-md-10">
                            <TextBox id="ConfirmNewPassword" @ref="ConfirmNewPassword" TextMode="@TextBoxMode.Password" CssClass="form-control" />
                            <RequiredFieldValidator ControlToValidate="ConfirmNewPassword"
                                CssClass="text-danger" Display="Dynamic" ErrorMessage="Confirm new password is required."
                                ValidationGroup="ChangePassword" />
                            <CompareValidator ControlToCompare="NewPassword" ControlToValidate="ConfirmNewPassword"
                                CssClass="text-danger" Display="Dynamic" ErrorMessage="The new password and confirmation password do not match."
                                ValidationGroup="ChangePassword" />
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <Button Text="Change Password" ValidationGroup="ChangePassword" OnClick="@ChangePassword_Click" CssClass="btn btn-default" />
                        </div>
                    </div>
                </div>
            </PlaceHolder>
        </section>
    </div>
