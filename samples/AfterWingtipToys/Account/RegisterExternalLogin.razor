@page "/RegisterExternalLogin"
<h3>Register with your external account</h3>
<div class="form-horizontal">
    <h4>Association Form</h4>
    <hr />
    <p class="text-danger"></p>
    <div class="form-group">
        <Label ID="EmailLabel" Text="Email" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="Email" CssClass="form-control" />
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <Button ID="LogInBtn" Text="Log in" CssClass="btn btn-default" />
        </div>
    </div>
</div>
