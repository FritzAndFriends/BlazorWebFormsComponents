@page "/ResetPasswordConfirmation"
<PageTitle>Password Changed</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <h2>@(Title).</h2>
            <div>
                <p>Your password has been changed. Click <HyperLink id="login" @ref="login" NavigateUrl="/Account/Login">here</HyperLink> to login </p>
            </div>
        </Content>
    </ChildComponents>
</Site>
