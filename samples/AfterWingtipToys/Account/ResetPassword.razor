@page "/Account/ResetPassword"
@rendermode InteractiveServer

<h2>Reset Password.</h2>
<p class="text-danger">@errorMessage</p>
<div class="form-horizontal">
    <h4>Reset your password.</h4>
    <hr />
    <div class="form-group">
        <Label ID="EmailLabel" Text="Email" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="Email" CssClass="form-control" TextMode="@TextBoxMode.Email"
                     Text="@email" TextChanged="@(v => email = v)" />
        </div>
    </div>
    <div class="form-group">
        <Label ID="PasswordLabel" Text="Password" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="Password" CssClass="form-control" TextMode="@TextBoxMode.Password"
                     Text="@password" TextChanged="@(v => password = v)" />
        </div>
    </div>
    <div class="form-group">
        <Label ID="ConfirmLabel" Text="Confirm password" CssClass="col-md-2 control-label" />
        <div class="col-md-10">
            <TextBox ID="ConfirmPassword" CssClass="form-control" TextMode="@TextBoxMode.Password"
                     Text="@confirmPassword" TextChanged="@(v => confirmPassword = v)" />
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <Button ID="ResetBtn" Text="Reset" CssClass="btn btn-default" OnClick="HandleReset" />
        </div>
    </div>
</div>
