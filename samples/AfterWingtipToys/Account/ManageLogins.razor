@page "/ManageLogins"
<h2>Manage your external logins.</h2>
    <PlaceHolder ID="successMessage" Visible="false">
            <p class="text-success">@(SuccessMessage)</p>
        </PlaceHolder>
    <div>
        <section id="externalLoginsForm">

            <ListView
                ItemType="UserLoginInfo"
                SelectMethod="@GetLogins" DeleteMethod="RemoveLogin" DataKeyNames="LoginProvider,ProviderKey">
@* TODO: SelectMethod="GetLogins" preserved — convert to delegate: SelectMethod="@((maxRows, startRow, sort, out total) => YourService.GetLogins(maxRows, startRow, sort, out total))" *@

                <LayoutTemplate>
                    <h4>Registered Logins</h4>
                    <table class="table">
                        <tbody>
                            @context
                        </tbody>
                    </table>

                </LayoutTemplate>
                <ItemTemplate>
                    <tr>
                        <td>@context.LoginProvider</td>
                        <td>
                            @* TODO: ToolTip and Visible attributes used Web Forms <%# %> data-binding syntax — migrate to Blazor *@
                            <Button Text="Remove" CommandName="Delete" CausesValidation="false"
                                CssClass="btn btn-default" />
                        </td>
                    </tr>
                </ItemTemplate>
            </ListView>

        </section>
    </div>
    <div>
        <OpenAuthProviders ReturnUrl="~/Account/ManageLogins" />
    </div>

