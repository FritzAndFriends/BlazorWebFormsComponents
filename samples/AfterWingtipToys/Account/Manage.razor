@page "/Account/Manage"
@inject UserStoreService UserStore

<PageTitle>Manage your account</PageTitle>
<Site>
    <Content ContentPlaceHolderID="MainContent">
        <h1>Manage your account</h1>
        @if (string.IsNullOrWhiteSpace(CurrentUser))
        {
            <p>Please <a href="/Account/Login">log in</a> to manage your account.</p>
        }
        else
        {
            <p>You are signed in as <strong>@CurrentUser</strong>.</p>
            <p><a href="/Account/Logout">Log out</a></p>
        }
    </Content>
</Site>

@code {
    private string? CurrentUser => UserStore.GetCurrentUserEmail();
}
