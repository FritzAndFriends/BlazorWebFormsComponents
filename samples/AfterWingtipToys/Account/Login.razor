@page "/Login"
<h2>Log In.</h2>

<div class="row">
    <div class="col-md-8">
        <section id="loginForm">
            <div class="form-horizontal">
                <h4>Use a local account to log in.</h4>
                <hr />
                <p class="text-danger"></p>
                <div class="form-group">
                    <Label ID="EmailLabel" Text="Email" CssClass="col-md-2 control-label" />
                    <div class="col-md-10">
                        <TextBox ID="Email" CssClass="form-control" TextMode="@TextBoxMode.Email" />
                    </div>
                </div>
                <div class="form-group">
                    <Label ID="PasswordLabel" Text="Password" CssClass="col-md-2 control-label" />
                    <div class="col-md-10">
                        <TextBox ID="Password" CssClass="form-control" TextMode="@TextBoxMode.Password" />
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-md-offset-2 col-md-10">
                        <Button ID="LogInBtn" Text="Log in" CssClass="btn btn-default" />
                    </div>
                </div>
            </div>
            <p>
                <a href="/Account/Forgot">Forgot your password?</a>
            </p>
            <p>
                <a href="/Account/Register">Register as a new user</a>
            </p>
        </section>
    </div>
</div>
