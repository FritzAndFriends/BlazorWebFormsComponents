@inject CatalogService Catalog
@inject CartService Cart
@inject UserStoreService UserStore

<MasterPage>
    <Head>
        <link href="/favicon.ico" rel="shortcut icon" type="image/x-icon" />
    </Head>
    <ChildContent>
        <div class="navbar navbar-inverse navbar-fixed-top">
            <div class="container-fluid" style="min-height: 70px;">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                    <a class="navbar-brand" href="/">Wingtip Toys</a>
                </div>
                <div class="navbar-collapse collapse">
                    <ul class="nav navbar-nav">
                        <li><a href="/">Home</a></li>
                        <li><a href="/About">About</a></li>
                        <li><a href="/Contact">Contact</a></li>
                        <li><a href="/ProductList">ProductList</a></li>
                        <li><a href="/ShoppingCart">Cart (@Cart.GetCount())</a></li>
                    </ul>
                    @if (string.IsNullOrWhiteSpace(CurrentUserEmail))
                    {
                        <ul class="nav navbar-nav navbar-right">
                            <li><a href="/Account/Register">Register</a></li>
                            <li><a href="/Account/Login">Log in</a></li>
                        </ul>
                    }
                    else
                    {
                        <ul class="nav navbar-nav navbar-right">
                            <li><a href="/Account/Manage" title="Manage your account">Hello, @CurrentUserEmail!</a></li>
                            <li><a href="/Account/Logout">Log out</a></li>
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div id="TitleContent" style="text-align: center; margin-top: 70px;">
            <a href="/">
                <img src="/Images/logo.jpg" alt="Wingtip Toys" />
            </a>
            <br />
        </div>

        <div id="CategoryMenu" style="text-align: center; margin-bottom: 20px;">
            @foreach (var category in Catalog.GetCategories())
            {
                <span style="font-size: large; font-style: normal; margin: 0 8px;">
                    <a href="/ProductList?id=@category.CategoryID">@category.CategoryName</a>
                </span>
            }
        </div>

        <div class="container body-content" role="main" style="min-height: 420px;">
            <ContentPlaceHolder ID="MainContent" />
            <hr />
            <footer>
                <p>&copy; 2013 - Wingtip Toys</p>
            </footer>
        </div>
    </ChildContent>
    <ChildComponents>
        @ChildComponents
        @ChildContent
    </ChildComponents>
</MasterPage>

@code {
    [Parameter]
    public RenderFragment? ChildComponents { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string? CurrentUserEmail => UserStore.GetCurrentUserEmail();
}
