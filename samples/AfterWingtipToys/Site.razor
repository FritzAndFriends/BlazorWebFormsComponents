@using Microsoft.AspNetCore.Http
@using WingtipToys.Services
@inject CatalogService CatalogService
@inject CartService CartService

<div class="navbar navbar-inverse navbar-fixed-top">
    <div class="container">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <a class="navbar-brand" href="/">Wingtip Toys</a>
        </div>
        <div class="navbar-collapse collapse">
            <ul class="nav navbar-nav">
                <li><a href="/">Home</a></li>
                <li><a href="/About">About</a></li>
                <li><a href="/Contact">Contact</a></li>
                <li><a href="/ProductList">Products</a></li>
                <li><a href="/ShoppingCart">@CartLabel</a></li>
            </ul>
            <AuthorizeView>
                <NotAuthorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Account/Register">Register</a></li>
                        <li><a href="/Account/Login">Log in</a></li>
                    </ul>
                </NotAuthorized>
                <Authorized>
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="/Manage">Hello, @Context.User.Identity?.Name!</a></li>
                        <li><a href="/Account/Logout">Log out</a></li>
                    </ul>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>
<div id="TitleContent" style="text-align: center">
    <a href="/">
        <img src="/Images/logo.jpg" alt="Wingtip Toys" class="img-responsive center-block" />
    </a>
    <br />
</div>
<div id="CategoryMenu" style="text-align: center">
    <ListView Items="@Categories" ItemType="Category" Context="Item">
        <ItemTemplate>
            <b style="font-size: large; font-style: normal">
                <a href="/ProductList?categoryId=@Item.CategoryID">@Item.CategoryName</a>
            </b>
        </ItemTemplate>
        <ItemSeparatorTemplate> | </ItemSeparatorTemplate>
    </ListView>
</div>
<div class="container body-content">
    @ChildContent
    <hr />
    <footer>
        <p>&copy; 2013 - Wingtip Toys</p>
    </footer>
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private IReadOnlyList<Category> Categories { get; set; } = Array.Empty<Category>();

    private string CartLabel => $"Cart ({CartService.GetCount(GetCartId())})";

    protected override void OnInitialized()
    {
        Categories = CatalogService.GetCategories();
    }

    private string GetCartId()
    {
        if (!string.IsNullOrWhiteSpace(Context?.User?.Identity?.Name))
        {
            return Context.User.Identity.Name;
        }

        var cartId = Context?.Session.GetString("CartId");
        if (!string.IsNullOrWhiteSpace(cartId))
        {
            return cartId;
        }

        cartId = Guid.NewGuid().ToString("N");
        Context?.Session.SetString("CartId", cartId);
        return cartId;
    }
}
