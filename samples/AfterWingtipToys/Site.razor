<div id="TitleContent" style="text-align: center; margin-top: 70px;">
    <a href="/">
        <img src="/Images/logo.jpg" alt="Wingtip Toys" />
    </a>
    <br />
</div>
<div id="CategoryMenu" style="text-align: center">
    <ListView Items="Categories" ItemType="Category">
        <ItemTemplate Context="Item">
            <b style="font-size: large; font-style: normal">
                <a href="/Category/@Item.CategoryName">@Item.CategoryName</a>
            </b>
        </ItemTemplate>
        <ItemSeparatorTemplate> | </ItemSeparatorTemplate>
    </ListView>
</div>
<div class="container body-content">
    @ChildComponents
    <hr />
    <footer>
        <p>&copy; 2013 - Wingtip Toys</p>
    </footer>
</div>

@using WingtipToys.Logic

@code {
    [Inject]
    private ProductContext ProductContext { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? ChildComponents { get; set; }

    private List<Category> Categories { get; set; } = [];

    private string CartCountText { get; set; } = "Cart (0)";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        Categories = await Task.FromResult(ProductContext.Categories.OrderBy(c => c.CategoryID).ToList());

        try
        {
            using var cart = new ShoppingCartActions();
            CartCountText = $"Cart ({cart.GetCount()})";
        }
        catch
        {
            CartCountText = "Cart (0)";
        }
    }
}
