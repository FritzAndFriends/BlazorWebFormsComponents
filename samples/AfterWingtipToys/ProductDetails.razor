@page "/ProductDetails"
@if (_product != null)
{
<FormView Items="@(new List<Product> { _product })" RenderOuterTable="@false">
    <ItemTemplate>
        <div>
            <h1>@context.ProductName</h1>
        </div>
        <br />
        <table>
            <tr>
                <td>
                    <img src="/Catalog/Images/@context.ImagePath" style="border:solid; height:300px" alt="@context.ProductName"/>
                </td>
                <td>&nbsp;</td>  
                <td style="vertical-align: top; text-align:left;">
                    <b>Description:</b><br />@context.Description
                    <br />
                    <span><b>Price:</b>&nbsp;@($"{context.UnitPrice:c}")</span>
                    <br />
                    <span><b>Product Number:</b>&nbsp;@context.ProductID</span>
                    <br />
                    <br />
                    <a href="/AddToCart?productID=@context.ProductID" onclick="event.preventDefault(); window.location.href=this.href;" class="btn btn-default">Add To Cart</a>
                </td>
            </tr>
        </table>
    </ItemTemplate>
</FormView>
}
else
{
    <p>Product not found.</p>
}

