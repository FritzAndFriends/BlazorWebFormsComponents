@page "/ProductList"
@inject CatalogService Catalog

<PageTitle>Products</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <section>
                <div>
                    <hgroup>
                        <h2>Products</h2>
                    </hgroup>

                    <ListView id="productList"
                              DataKeyNames="ProductID"
                              GroupItemCount="4"
                              ItemType="Product"
                              SelectItems="GetProducts">
                        <EmptyDataTemplate>
                            <table>
                                <tr>
                                    <td>No data was returned.</td>
                                </tr>
                            </table>
                        </EmptyDataTemplate>
                        <EmptyItemTemplate>
                            <td></td>
                        </EmptyItemTemplate>
                        <GroupTemplate Context="items">
                            <tr id="itemPlaceholderContainer">
                                @items
                            </tr>
                        </GroupTemplate>
                        <ItemTemplate Context="Item">
                            <td>
                                <table>
                                    <tr>
                                        <td>
                                            <a href="/ProductDetails?productName=@Uri.EscapeDataString(Item.ProductName)">
                                                <img src="/Catalog/Images/Thumbs/@Item.ImagePath"
                                                     width="100"
                                                     height="75"
                                                     border="1"
                                                     alt="@Item.ProductName" />
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <a href="/ProductDetails?productName=@Uri.EscapeDataString(Item.ProductName)">
                                                @Item.ProductName
                                            </a>
                                            <br />
                                            <span>
                                                <b>Price: </b>@(String.Format("{0:c}", Item.UnitPrice))
                                            </span>
                                            <br />
                                            <a href="/AddToCart?productID=@Item.ProductID">
                                                <span class="ProductListItem"><b>Add To Cart</b></span>
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>&nbsp;</td>
                                    </tr>
                                </table>
                            </td>
                        </ItemTemplate>
                        <LayoutTemplate Context="groups">
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td>
                                            <table id="groupPlaceholderContainer" style="width:100%">
                                                @groups
                                            </table>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </LayoutTemplate>
                    </ListView>
                </div>
            </section>
        </Content>
    </ChildComponents>
</Site>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "id")]
    public int? CategoryId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "categoryName")]
    public string? CategoryName { get; set; }

    private IEnumerable<Product> GetProducts(int maxRows, int startRowIndex, string sortByExpression)
        => Catalog.GetProducts(CategoryId, CategoryName);
}
