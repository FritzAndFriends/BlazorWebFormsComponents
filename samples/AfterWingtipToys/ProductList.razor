@page "/ProductList"
@page "/Category/{CategoryName}"
<PageTitle>Products</PageTitle>
<Site>
<Content ContentPlaceHolderID="MainContent">
    <section>
        <div>
            <hgroup>
                <h2>@(Page.Title)</h2>
            </hgroup>

            <ListView id="productList" @ref="productList"
                DataKeyNames="ProductID" GroupItemCount="4"
                TItem="Product" Items="Products">
                <EmptyDataTemplate>
                    <table>
                        <tr>
                            <td>No data was returned.</td>
                        </tr>
                    </table>
                </EmptyDataTemplate>
                <EmptyItemTemplate>
                    <td />
                </EmptyItemTemplate>
                <GroupTemplate>
                    <tr id="itemPlaceholderContainer">
                        @context
                    </tr>
                </GroupTemplate>
                <ItemTemplate Context="Item">
                    <td>
                        <table>
                            <tr>
                                <td>
                                    <a href="@($"/ProductDetails?ProductID={Item.ProductID}")">
                                        <img src='@($"/Catalog/Images/Thumbs/{Item.ImagePath}")'
                                             width="100" height="75" border="1" alt="@Item.ProductName" />
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@($"/ProductDetails?ProductID={Item.ProductID}")">
                                        @Item.ProductName
                                    </a>
                                    <br />
                                    <span>
                                        <b>Price: </b>@($"{Item.UnitPrice:c}")
                                    </span>
                                    <br />
                                    <a href="@($"/AddToCart?productID={Item.ProductID}")">
                                        <span class="ProductListItem">
                                            <b>Add To Cart</b>
                                        </span>
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td>&nbsp;</td>
                            </tr>
                        </table>
                    </td>
                </ItemTemplate>
                <LayoutTemplate>
                    <table style="width:100%;">
                        <tbody>
                            <tr>
                                <td>
                                    <table id="groupPlaceholderContainer" style="width:100%">
                                        @context
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                            </tr>
                            <tr></tr>
                        </tbody>
                    </table>
                </LayoutTemplate>
            </ListView>
        </div>
    </section>
</Content>
</Site>
