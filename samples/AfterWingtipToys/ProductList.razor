@page "/ProductList"
@page "/Category/{categoryName}"
<WebFormsForm @formname="ProductListForm">
    <AntiforgeryToken />
<PageTitle>Products</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <section>
                <div>
                    <h2>Products</h2>
                    <ListView ItemType="Product" Items="@Products">
                        <EmptyDataTemplate>
                            <p>No products were found.</p>
                        </EmptyDataTemplate>
                        <LayoutTemplate Context="items">
                            <div class="row">@items</div>
                        </LayoutTemplate>
                        <ItemTemplate Context="Item">
                            <div class="col-sm-3">
                                <div class="thumbnail">
                                    <a href="/ProductDetails?productId=@Item.ProductID">
                                        <img src="/Catalog/Images/Thumbs/@Item.ImagePath" alt="@Item.ProductName" style="width:100%;height:160px;object-fit:contain" />
                                    </a>
                                    <br />
                                    <span>
                                        <b>Price: </b>@(String.Format("{0:c}", Item.UnitPrice))
                                    </span>
                                    <br />
                                    <a href="/AddToCart.aspx?productID=@Item.ProductID" data-enhance-nav="false">               
                                        <span class="ProductListItem">
                                            <b>Add To Cart</b>
                                        </span>           
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td>&nbsp;</td>
                            </tr>
                        </table>
                    </td>
                </ItemTemplate>
                <LayoutTemplate Context="groups">
                    <table style="width:100%;">
                        <tbody>
                            <tr>
                                <td>
                                    <table id="groupPlaceholderContainer" style="width:100%">
                                        @groups
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                            </tr>
                            <tr></tr>
                        </tbody>
                    </table>
                </LayoutTemplate>
            </ListView>
        </div>
    </section>

</WebFormsForm>
