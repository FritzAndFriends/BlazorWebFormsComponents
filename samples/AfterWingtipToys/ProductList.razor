@page "/ProductList"
@inject CatalogService CatalogService

<PageTitle>Products</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <section>
                <div>
                    <hgroup>
                        <h2>Products</h2>
                    </hgroup>

                    <ListView Items="@Products" GroupItemCount="4">
                        <EmptyDataTemplate>
                            <table>
                                <tr>
                                    <td>No products were found.</td>
                                </tr>
                            </table>
                        </EmptyDataTemplate>
                        <EmptyItemTemplate>
                            <td></td>
                        </EmptyItemTemplate>
                        <GroupTemplate Context="items">
                            <tr>
                                @items
                            </tr>
                        </GroupTemplate>
                        <ItemTemplate Context="Item">
                            <td>
                                <table>
                                    <tr>
                                        <td>
                                            <a href="/ProductDetails?productID=@Item.ProductID">
                                                <img src="/Catalog/Images/Thumbs/@Item.ImagePath" width="100" height="75" border="1" alt="@Item.ProductName" />
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <a href="/ProductDetails?productID=@Item.ProductID">@Item.ProductName</a>
                                            <br />
                                            <span><b>Price:</b> @(String.Format("{0:c}", Item.UnitPrice))</span>
                                            <br />
                                            <a href="/AddToCart?productID=@Item.ProductID">
                                                <span class="ProductListItem"><b>Add To Cart</b></span>
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>&nbsp;</td>
                                    </tr>
                                </table>
                            </td>
                        </ItemTemplate>
                        <LayoutTemplate Context="content">
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td>
                                            <table style="width:100%">
                                                @content
                                            </table>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </LayoutTemplate>
                    </ListView>
                </div>
            </section>
        </Content>
    </ChildComponents>
</Site>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "categoryId")]
    public int? CategoryId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "categoryName")]
    public string? CategoryName { get; set; }

    private IReadOnlyList<Product> Products => CatalogService.GetProducts(CategoryId, CategoryName);
}
