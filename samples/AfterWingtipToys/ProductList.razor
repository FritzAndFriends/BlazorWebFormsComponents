@page "/ProductList"
@inject WingtipToys.Models.ProductContext _db
<PageTitle>Products</PageTitle>
	
    <section>
        <div>
            <hgroup>
                <h2>Products</h2>
            </hgroup>

            <ListView 
                DataKeyNames="ProductID" GroupItemCount="4"
                ItemType="Product" DataSource="@_products">
                <EmptyDataTemplate>
                    <table >
                        <tr>
                            <td>No data was returned.</td>
                        </tr>
                    </table>
                </EmptyDataTemplate>
                <EmptyItemTemplate>
                    <td/>
                </EmptyItemTemplate>
                <GroupTemplate Context="items">
                    <tr id="itemPlaceholderContainer">
                        @items
                    </tr>
                </GroupTemplate>
                <ItemTemplate Context="Item">
                    <td>
                        <table>
                            <tr>
                                <td>
                                  <a href="/ProductDetails?ProductID=@Item.ProductID">
                                    <img src='/Catalog/Images/Thumbs/@Item.ImagePath'
                                      width="100" height="75" style="border:1px solid #ccc" />
                                  </a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="/ProductDetails?ProductID=@Item.ProductID">
                                      @Item.ProductName
                                    </a>
                                    <br />
                                    <span>
                                        <b>Price: </b>@(String.Format("{0:c}", Item.UnitPrice))
                                    </span>
                                    <br />
                                    <a href="/AddToCart?productID=@Item.ProductID" data-enhance-nav="false">               
                                        <span class="ProductListItem">
                                            <b>Add To Cart</b>
                                        </span>           
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td>&nbsp;</td>
                            </tr>
                        </table>
                    </td>
                </ItemTemplate>
                <LayoutTemplate Context="groups">
                    <table style="width:100%;">
                        <tbody>
                            <tr>
                                <td>
                                    <table id="groupPlaceholderContainer" style="width:100%">
                                        @groups
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                            </tr>
                            <tr></tr>
                        </tbody>
                    </table>
                </LayoutTemplate>
            </ListView>
        </div>
    </section>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "id")] public int? CategoryId { get; set; }

    private IEnumerable<Product> _products = Enumerable.Empty<Product>();

    protected override void OnInitialized()
    {
        IQueryable<Product> query = _db.Products.Include(p => p.Category);
        if (CategoryId.HasValue && CategoryId > 0)
        {
            query = query.Where(p => p.CategoryID == CategoryId);
        }
        _products = query.ToList();
    }
}
