@page "/ProductList"
@page "/Category/{CategoryName}"

<PageTitle>Products</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <section>
                <div>
                    <hgroup>
                        <h2>@Title</h2>
                    </hgroup>

                    <ListView ItemType="Product" Items="@Products" GroupItemCount="4" Context="Item">
                        <EmptyDataTemplate>
                            <table>
                                <tr>
                                    <td>No data was returned.</td>
                                </tr>
                            </table>
                        </EmptyDataTemplate>
                        <EmptyItemTemplate>
                            <td></td>
                        </EmptyItemTemplate>
                        <GroupTemplate Context="items">
                            <tr>
                                @items
                            </tr>
                        </GroupTemplate>
                        <ItemTemplate>
                            <td>
                                <table>
                                    <tr>
                                        <td>
                                            <a href="/ProductDetails?ProductID=@Item.ProductID">
                                                <img src="/Catalog/Images/Thumbs/@Item.ImagePath" width="100" height="75" border="1" alt="@Item.ProductName" />
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <a href="/ProductDetails?ProductID=@Item.ProductID">@Item.ProductName</a>
                                            <br />
                                            <span><b>Price: </b>@(String.Format("{0:c}", Item.UnitPrice))</span>
                                            <br />
                                            <a href="/AddToCart?productID=@Item.ProductID">
                                                <span class="ProductListItem"><b>Add To Cart</b></span>
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>&nbsp;</td>
                                    </tr>
                                </table>
                            </td>
                        </ItemTemplate>
                        <LayoutTemplate Context="groups">
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td>
                                            <table style="width:100%">
                                                <tbody>
                                                    @groups
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </LayoutTemplate>
                    </ListView>
                </div>
            </section>
        </Content>
    </ChildComponents>
</Site>