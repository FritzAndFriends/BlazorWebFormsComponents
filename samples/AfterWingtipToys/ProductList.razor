@page "/ProductList"
@page "/Category/{categoryName}"
@inherits BlazorWebFormsComponents.WebFormsPageBase
<PageTitle>Products</PageTitle>

<section>
    <div>
        <hgroup>
            <h2>@(categoryName ?? "Products")</h2>
        </hgroup>

        <ListView Items="products" ItemType="Product" DataKeyNames="ProductID" GroupItemCount="4">
            <EmptyDataTemplate>
                <table>
                    <tr>
                        <td>No data was returned.</td>
                    </tr>
                </table>
            </EmptyDataTemplate>
            <EmptyItemTemplate>
                <td />
            </EmptyItemTemplate>
            <GroupTemplate Context="items">
                <tr id="itemPlaceholderContainer">
                    @items
                </tr>
            </GroupTemplate>
            <ItemTemplate Context="Item">
                <td>
                    <table>
                        <tr>
                            <td>
                                <a href="@($"/Product/{Item.ProductName}")">
                                    <img src="/Catalog/Images/Thumbs/@Item.ImagePath" width="100" height="75" border="1" alt="@Item.ProductName" />
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <a href="@($"/Product/{Item.ProductName}")">
                                    @Item.ProductName
                                </a>
                                <br />
                                <span>
                                    <b>Price: </b>@(String.Format("{0:c}", Item.UnitPrice))
                                </span>
                                <br />
                                <a href="/AddToCart?productID=@Item.ProductID" data-enhance-nav="false">
                                    <span class="ProductListItem">
                                        <b>Add To Cart</b>
                                    </span>
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td>&nbsp;</td>
                        </tr>
                    </table>
                </td>
            </ItemTemplate>
            <LayoutTemplate Context="groups">
                <table style="width:100%;">
                    <tbody>
                        <tr>
                            <td>
                                <table id="groupPlaceholderContainer" style="width:100%">
                                    @groups
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </LayoutTemplate>
        </ListView>
    </div>
</section>
