@page "/ProductList"
<PageTitle>Products</PageTitle>
	
    <section>
        <div>
            <hgroup>
                <h2>@(Page.Title)</h2>
            </hgroup>

            <ListView id="productList" @ref="productList" 
                DataKeyNames="ProductID" GroupItemCount="4"
                ItemType="Product" SelectMethod="GetProductsQueryDetails_SelectMethod">
                <EmptyDataTemplate>
                    <table >
                        <tr>
                            <td>No data was returned.</td>
                        </tr>
                    </table>
                </EmptyDataTemplate>
                <EmptyItemTemplate>
                    <td/>
                </EmptyItemTemplate>
                <GroupTemplate Context="items">
                    <tr id="itemPlaceholderContainer">
                        @items
                    </tr>
                </GroupTemplate>
                <ItemTemplate Context="Item">
                    <td>
                        <table>
                            <tr>
                                <td>
                                  <a href="/ProductDetails?productName=@(Uri.EscapeDataString(Item.ProductName))" data-enhance-nav="false">
                                    <img src="/Catalog/Images/Thumbs/@Item.ImagePath"
                                         width="100" height="75" border="1" />
                                  </a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="/ProductDetails?productName=@(Uri.EscapeDataString(Item.ProductName))" data-enhance-nav="false">
                                      @Item.ProductName
                                    </a>
                                    <br />
                                    <span>
                                        <b>Price: </b>@(String.Format("{0:c}", Item.UnitPrice))
                                    </span>
                                    <br />
                                    <a href="/AddToCart?productID=@Item.ProductID" data-enhance-nav="false">
                                        <span class="ProductListItem">
                                            <b>Add To Cart</b>
                                        </span>
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td>&nbsp;</td>
                            </tr>
                        </table>
                    </td>
                </ItemTemplate>
                <LayoutTemplate Context="groups">
                    <table style="width:100%;">
                        <tbody>
                            <tr>
                                <td>
                                    <table id="groupPlaceholderContainer" style="width:100%">
                                        @groups
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                            </tr>
                            <tr></tr>
                        </tbody>
                    </table>
                </LayoutTemplate>
            </ListView>
        </div>
    </section>

