@page "/ProductList"
	<section>
        <div>
            <hgroup>
                <h2>Products</h2>
            </hgroup>

            <ListView ID="productList" 
                DataKeyNames="ProductID"
                TItem="Product" Items="@Products">
                <EmptyDataTemplate>
                    <table>
                        <tr>
                            <td>No data was returned.</td>
                        </tr>
                    </table>
                </EmptyDataTemplate>
                <ItemTemplate>
                    <td style="padding:10px;vertical-align:top;">
                        <table>
                            <tr>
                                <td>
                                  <a href="@($"/ProductDetails?id={context.ProductID}")">
                                    <img src="/Images/Products/@context.ImagePath"
                                      width="100" height="75" style="border:1px solid" />
                                  </a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@($"/ProductDetails?id={context.ProductID}")">
                                      <b>@context.ProductName</b>
                                    </a>
                                    <br />
                                    <span>
                                        <b>Price: </b>@($"{context.UnitPrice:c}")
                                    </span>
                                    <br />
                                    <a href="@($"/AddToCart?productID={context.ProductID}")">
                                        <span class="ProductListItem">
                                            <b>Add To Cart</b>
                                        </span>           
                                    </a>
                                </td>
                            </tr>
                        </table>
                    </td>
                </ItemTemplate>
            </ListView>
        </div>
    </section>

