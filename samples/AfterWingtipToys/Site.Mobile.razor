<MasterPage>
    <ChildContent>
        @ChildComponents
        <ContentPlaceHolder id="MainContent" />
        @ChildContent
    </ChildContent>
</MasterPage>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? ChildComponents { get; set; }
}
