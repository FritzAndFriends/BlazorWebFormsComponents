@page "/"
<PageTitle>Home</PageTitle>

<div class="jumbotron" style="min-height: 260px; padding: 48px 60px;">
    <h1>Wingtip Toys</h1>
    <p class="lead">
        Wingtip Toys can help you find the perfect gift. Browse our transportation-themed
        catalog, review detailed product pages, and build a shopping cart without leaving
        the migrated Blazor app.
    </p>
    <p>
        <a class="btn btn-primary btn-lg" href="/ProductList">Shop now</a>
    </p>
</div>

<div class="row">
