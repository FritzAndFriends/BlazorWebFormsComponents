@page "/"
<PageTitle>Wingtip Toys</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <div class="jumbotron">
                <h1>Wingtip Toys</h1>
                <p class="lead">Wingtip Toys can help you find the perfect gift.</p>
                <p>We're all about transportation toys. Explore the catalog, view product details, and add items to your cart.</p>
                <p><a class="btn btn-primary btn-lg" href="/ProductList">Shop Now</a></p>
            </div>

            <h2>Featured Products</h2>
            <ListView ItemType="Product" Items="@FeaturedProducts">
                <LayoutTemplate Context="items">
                    <div class="row">@items</div>
                </LayoutTemplate>
                <ItemTemplate Context="Item">
                    <div class="col-sm-3">
                        <div class="thumbnail">
                            <a href="/ProductDetails?productId=@Item.ProductID">
                                <img src="/Catalog/Images/Thumbs/@Item.ImagePath" alt="@Item.ProductName" style="width:100%;height:160px;object-fit:contain" />
                            </a>
                            <div class="caption">
                                <h4><a href="/ProductDetails?productId=@Item.ProductID">@Item.ProductName</a></h4>
                                <p>@Item.Description</p>
                            </div>
                        </div>
                    </div>
                </ItemTemplate>
            </ListView>
        </Content>
    </ChildComponents>
</Site>
