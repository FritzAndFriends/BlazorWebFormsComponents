@page "/ShoppingCart"
@using WingtipToys.Logic
@using WingtipToys.Models

<PageTitle>Shopping Cart</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <div id="ShoppingCartTitle" class="ContentHead"><h1>Shopping Cart</h1></div>
            @if (!_cartItems.Any())
            {
                <p>Your cart is empty.</p>
            }
            else
            {
                <table class="table table-striped table-bordered" id="cartTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Price (each)</th>
                            <th>Quantity</th>
                            <th>Item Total</th>
                            <th>Remove</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var entry in _cartItems)
                    {
                        <tr>
                            <td>@entry.Product.ProductName</td>
                            <td>@($"{entry.Product.UnitPrice:c}")</td>
                            <td>
                                <input type="number" min="1"
                                       value="@_quantities[entry.Product.ProductID]"
                                       @onchange="@(e => UpdateQty(entry.Product.ProductID, e))" />
                            </td>
                            <td>@($"{(entry.Product.UnitPrice ?? 0) * _quantities[entry.Product.ProductID]:c}")</td>
                            <td>
                                <a href="/RemoveFromCart?productID=@entry.Product.ProductID">Remove</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
                <div>
                    <strong>Order Total: @($"{_total:c}")</strong>
                </div>
            }
            <br />
            <div class="shopping-cart-actions">
                <button type="button" @onclick="UpdateCart">Update</button>
                <button type="button" @onclick="Checkout">Checkout</button>
            </div>
        </Content>
    </ChildComponents>
</Site>

