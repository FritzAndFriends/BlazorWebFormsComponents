@page "/ShoppingCart"
@inject CartService Cart
@inject NavigationManager Navigation

<PageTitle>Shopping Cart</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <div id="ShoppingCartTitle" class="ContentHead">
                <h1>Shopping Cart</h1>
            </div>

            @if (Items.Count == 0)
            {
                <p>Your shopping cart is empty.</p>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Price (each)</th>
                            <th>Quantity</th>
                            <th>Item Total</th>
                            <th>Remove Item</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Items)
                        {
                            <tr>
                                <td>@item.Product.ProductID</td>
                                <td>@item.Product.ProductName</td>
                                <td>@($"{item.Product.UnitPrice:c}")</td>
                                <td>
                                    <form method="get" action="/Cart/Update" class="form-inline">
                                        <input type="hidden" name="productId" value="@item.Product.ProductID" />
                                        <input type="number" min="1" name="quantity" value="@item.Quantity" class="form-control" style="width: 80px;" />
                                        <button type="submit" class="btn btn-default">Update</button>
                                    </form>
                                </td>
                                <td>@($"{item.Product.UnitPrice * item.Quantity:c}")</td>
                                <td>
                                    <form method="get" action="/Cart/Remove">
                                        <input type="hidden" name="productId" value="@item.Product.ProductID" />
                                        <button type="submit" class="btn btn-link">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <p>
                    <strong>Order Total:</strong> @($"{Cart.GetTotal():c}")
                </p>
            }
        </Content>
    </ChildComponents>
</Site>

@code {
    private IReadOnlyList<CartService.CartLine> Items => Cart.GetItems();

    protected override void OnParametersSet()
    {
        var addProductId = TryGetIntQueryValue("addProductId");
        if (addProductId.HasValue)
        {
            Cart.AddToCart(addProductId.Value);
        }
    }

    private int? TryGetIntQueryValue(string key)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(key, out var value) && int.TryParse(value, out var parsed)
            ? parsed
            : null;
    }
}
