@page "/ShoppingCart"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject IHttpContextAccessor HttpContextAccessor
@inject IDbContextFactory<ProductContext> DbFactory
@inject WingtipToys.Logic.ShoppingCartService ShoppingCartService

<PageTitle>Shopping Cart</PageTitle>

<div id="ShoppingCartTitle" class="ContentHead"><h1>@ShoppingCartTitle</h1></div>
@if (CartItems.Count == 0)
{
    <p>Your shopping cart is empty.</p>
}
else
{
    <form method="post" action="/UpdateCart" data-enhance-nav="false">
        <GridView AutoGenerateColumns="false"
                  ShowFooter="true"
                  GridLines="@GridLines.Vertical"
                  CellPadding="4"
                  ItemType="CartItem"
                  Items="@CartItems"
                  CssClass="table table-striped table-bordered">
            <Columns>
                <BoundField ItemType="CartItem" DataField="ProductId" HeaderText="ID" SortExpression="ProductId" />
                <BoundField ItemType="CartItem" DataField="Product.ProductName" HeaderText="Name" />
                <BoundField ItemType="CartItem" DataField="Product.UnitPrice" HeaderText="Price (each)" DataFormatString="{0:c}" />
                <TemplateField ItemType="CartItem" HeaderText="Quantity">
                    <ItemTemplate Context="Item">
                        <input type="text" name="quantity-@Item.ProductId" value="@Item.Quantity" class="form-control" style="width:70px" />
                    </ItemTemplate>
                </TemplateField>
                <TemplateField ItemType="CartItem" HeaderText="Item Total">
                    <ItemTemplate Context="Item">
                        @FormatCurrency(Item.Quantity * Convert.ToDecimal(Item.Product?.UnitPrice ?? 0D))
                    </ItemTemplate>
                </TemplateField>
                <TemplateField ItemType="CartItem" HeaderText="Remove Item">
                    <ItemTemplate Context="Item">
                        <a href="/RemoveFromCart?productID=@Item.ProductId" data-enhance-nav="false">Remove</a>
                    </ItemTemplate>
                </TemplateField>
            </Columns>
        </GridView>
        <div>
            <p></p>
            <strong>
                <span>Order Total: </span>
                <span>@FormatCurrency(Total)</span>
            </strong>
        </div>
        <br />
        <table>
            <tr>
                <td>
                    <button type="submit" class="btn btn-default">Update</button>
                </td>
                <td>
                    <a href="/Checkout/CheckoutStart" class="btn btn-link">
                        <img src="https://www.paypal.com/en_US/i/btn/btn_xpressCheckout.gif" width="145" alt="Check out with PayPal" />
                    </a>
                </td>
            </tr>
        </table>
    </form>
}

@code {
    private List<CartItem> CartItems { get; set; } = [];

    private string ShoppingCartTitle { get; set; } = "Shopping Cart";

    private decimal Total { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadCartAsync();
    }

    private async Task LoadCartAsync()
    {
        CartItems = await ShoppingCartService.GetCartItemsAsync();
        Total = await ShoppingCartService.GetTotalAsync();
        ShoppingCartTitle = CartItems.Count > 0 ? "Shopping Cart" : "Shopping Cart is Empty";
    }

    private static string FormatCurrency(decimal amount) => string.Format("{0:c}", amount);
}
