@page "/ShoppingCart"
@inject CartStore CartStore

<PageTitle>Shopping Cart</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <div id="ShoppingCartTitle" class="ContentHead"><h1>@Heading</h1></div>
            <form method="post" @formname="shopping-cart-form">
                <AntiforgeryToken />
                <GridView ItemType="CartItem" AutoGenerateColumns="false" GridLines="@GridLines.Vertical" CellPadding="4"
                          Items="@CartItems" CssClass="table table-striped table-bordered">
                    <EmptyDataTemplate>
                        <div>Your shopping cart is empty.</div>
                    </EmptyDataTemplate>
                    <Columns>
                        <TemplateField ItemType="CartItem" HeaderText="ID">
                            <ItemTemplate Context="Item">@Item.ProductId</ItemTemplate>
                        </TemplateField>
                        <TemplateField ItemType="CartItem" HeaderText="Name">
                            <ItemTemplate Context="Item">@Item.Product.ProductName</ItemTemplate>
                        </TemplateField>
                        <TemplateField ItemType="CartItem" HeaderText="Price (each)">
                            <ItemTemplate Context="Item">@(String.Format("{0:c}", Item.Product.UnitPrice))</ItemTemplate>
                        </TemplateField>
                        <TemplateField ItemType="CartItem" HeaderText="Quantity">
                            <ItemTemplate Context="Item">
                                <input type="number" min="1" name="qty_@Item.ProductId" value="@Item.Quantity" class="form-control" style="width:80px" />
                            </ItemTemplate>
                        </TemplateField>
                        <TemplateField ItemType="CartItem" HeaderText="Item Total">
                            <ItemTemplate Context="Item">@(String.Format("{0:c}", ((Item.Product.UnitPrice ?? 0) * Item.Quantity)))</ItemTemplate>
                        </TemplateField>
                        <TemplateField ItemType="CartItem" HeaderText="Remove Item">
                            <ItemTemplate Context="Item">
                                <button type="submit" name="removeItem" value="@Item.ProductId" class="btn btn-link">Remove</button>
                            </ItemTemplate>
                        </TemplateField>
                    </Columns>
                </GridView>

                @if (CartItems.Count > 0)
                {
                    <div>
                        <p></p>
                        <strong>Order Total: @String.Format("{0:c}", OrderTotal)</strong>
                    </div>
                    <br />
                    <table>
                        <tr>
                            <td>
                                <button type="submit" name="updateCart" value="true" class="btn btn-default">Update</button>
                            </td>
                            <td style="padding-left:12px;">
                                <a class="btn btn-primary" href="/Checkout/CheckoutStart">Checkout</a>
                            </td>
                        </tr>
                    </table>
                }
                else
                {
                    <p>Your shopping cart is empty.</p>
                }
            </form>
        </Content>
    </ChildComponents>
</Site>

@code {
    private List<CartItem> CartItems { get; set; } = [];
    private decimal OrderTotal { get; set; }
    private string Heading { get; set; } = "Shopping Cart";

    protected override void OnInitialized()
    {
        var cartId = GetOrCreateCartId();
        if (IsPostBack)
        {
            if (int.TryParse(Request.Form["removeItem"], out var removeProductId))
            {
                CartStore.RemoveItem(cartId, removeProductId);
            }
            else
            {
                foreach (var item in CartStore.GetCartItems(cartId))
                {
                    if (int.TryParse(Request.Form[$"qty_{item.ProductId}"], out var quantity))
                    {
                        CartStore.UpdateQuantity(cartId, item.ProductId, quantity);
                    }
                }
            }
        }

        CartItems = CartStore.GetCartItems(cartId).ToList();
        OrderTotal = CartStore.GetTotal(cartId);
        Heading = CartItems.Count == 0 ? "Shopping Cart is Empty" : "Shopping Cart";
    }

    private string GetOrCreateCartId()
    {
        var cartId = Session[CartSessionKey]?.ToString();
        if (string.IsNullOrWhiteSpace(cartId))
        {
            cartId = Guid.NewGuid().ToString("N");
            Session[CartSessionKey] = cartId;
        }

        return cartId;
    }

    private const string CartSessionKey = "CartId";
}
