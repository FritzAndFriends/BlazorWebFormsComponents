@page "/ShoppingCart"
@rendermode InteractiveServer

<div class="ContentHead"><h1>Shopping Cart</h1></div>

@if (_cartItems != null && _cartItems.Any())
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price (each)</th>
                <th>Quantity</th>
                <th>Item Total</th>
                <th>Remove Item</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _cartItems)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.Product?.ProductName</td>
                    <td>@($"{item.Product?.UnitPrice:c}")</td>
                    <td>
                        <input type="number" style="width:60px" value="@item.Quantity"
                               @onchange="async (e) => await UpdateQuantity(item.ItemId, e)" />
                    </td>
                    <td>@($"{(item.Quantity * (item.Product?.UnitPrice ?? 0)):c}")</td>
                    <td>
                        <a href="/RemoveFromCart?itemId=@item.ItemId" data-enhance-nav="false" class="btn btn-danger btn-sm">Remove</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div>
        <p></p>
        <strong>
            Order Total: @($"{_cartItems.Sum(i => i.Quantity * (i.Product?.UnitPrice ?? 0)):c}")
        </strong>
    </div>
    <br />
    <table>
        <tr>
            <td>
                <button class="btn btn-default" @onclick="RefreshCart">Update</button>
            </td>
        </tr>
    </table>
}
else
{
    <p>Your shopping cart is empty.</p>
}

@code {
    [Inject] private CartStateService CartService { get; set; } = default!;

    private List<CartItem>? _cartItems;

    protected override async Task OnInitializedAsync()
    {
        Page.Title = "Shopping Cart";
        _cartItems = await CartService.GetCartItemsAsync();
    }

    private async Task UpdateQuantity(string itemId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int qty) && qty > 0)
        {
            await CartService.UpdateQuantityAsync(itemId, qty);
            _cartItems = await CartService.GetCartItemsAsync();
        }
    }

    private async Task RemoveItem(string itemId)
    {
        await CartService.RemoveItemAsync(itemId);
        _cartItems = await CartService.GetCartItemsAsync();
    }

    private async Task RefreshCart()
    {
        _cartItems = await CartService.GetCartItemsAsync();
    }
}
