@page "/ShoppingCart"
<PageTitle>Shopping Cart</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <div id="ShoppingCartTitle" class="ContentHead"><h1>@ShoppingCartTitleText</h1></div>

            @if (ShoppingCartItems.Count == 0)
            {
                <p>Your shopping cart is empty.</p>
            }
            else
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Price (each)</th>
                            <th>Quantity</th>
                            <th>Item Total</th>
                            <th>Remove Item</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ShoppingCartItems)
                        {
                            <tr>
                                <td>@item.ProductId</td>
                                <td>@item.Product?.ProductName</td>
                                <td>@($"{item.Product?.UnitPrice:c}")</td>
                                <td>
                                    <form method="get" action="/ShoppingCart/Update">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="number" min="1" name="quantity" value="@item.Quantity" style="width:60px" />
                                        <button type="submit" class="btn btn-default">Update</button>
                                    </form>
                                </td>
                                <td>@($"{(Convert.ToDouble(item.Quantity) * Convert.ToDouble(item.Product?.UnitPrice ?? 0)):c}")</td>
                                <td>
                                    <form method="get" action="/ShoppingCart/Remove">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn btn-link">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div>
                    <strong>Order Total: @OrderTotalText</strong>
                </div>
            }
        </Content>
    </ChildComponents>
</Site>
