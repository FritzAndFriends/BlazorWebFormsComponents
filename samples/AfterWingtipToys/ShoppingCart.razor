@page "/ShoppingCart"
@inject CartStateService CartService
@inject NavigationManager Nav

<div id="ShoppingCartTitle" class="ContentHead"><h1>@_title</h1></div>

@if (_cartItems != null && _cartItems.Any())
{
    <table class="table table-striped table-bordered" cellpadding="4">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price (each)</th>
                <th>Quantity</th>
                <th>Item Total</th>
                <th>Remove Item</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _cartItems)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.Product.ProductName</td>
                    <td>@($"{item.Product.UnitPrice:c}")</td>
                    <td>@item.Quantity</td>
                    <td>@($"{(Convert.ToDouble(item.Quantity) * Convert.ToDouble(item.Product.UnitPrice)):c}")</td>
                    <td>
                        <button class="btn btn-sm btn-danger" @onclick="() => RemoveItemAsync(item.ItemId)">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div>
        <p></p>
        <strong>
            Order Total: @($"{_total:c}")
        </strong>
    </div>
}

@code {
    private List<CartItem>? _cartItems;
    private decimal _total;
    private string _title = "Shopping Cart";

    protected override async Task OnInitializedAsync()
    {
        await LoadCartAsync();
    }

    private async Task LoadCartAsync()
    {
        _cartItems = await CartService.GetCartItemsAsync();
        _total = await CartService.GetTotalAsync();
        if (_cartItems == null || !_cartItems.Any())
        {
            _title = "Shopping Cart is Empty";
        }
    }

    private async Task RemoveItemAsync(string itemId)
    {
        await CartService.RemoveCartItemAsync(itemId);
        await LoadCartAsync();
    }
}

