@page "/ShoppingCart"
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
<PageTitle>Shopping Cart</PageTitle>

<div id="ShoppingCartTitle" class="ContentHead">
    <h1>@shoppingCartTitle</h1>
</div>

@if (cartItems.Count > 0)
{
    <GridView AutoGenerateColumns="false" ShowFooter="true" GridLines="@GridLines.Vertical" CellPadding="4"
              ItemType="CartItem" DataSource="@cartItems" CssClass="table table-striped table-bordered">
        <Columns>
            <BoundField DataField="ProductId" HeaderText="ID" SortExpression="ProductId" />
            <BoundField DataField="Product.ProductName" HeaderText="Name" />
            <TemplateField HeaderText="Price (each)">
                <ItemTemplate Context="Item">@((Item.Product?.UnitPrice ?? 0).ToString("c"))</ItemTemplate>
            </TemplateField>
            <TemplateField HeaderText="Quantity">
                <ItemTemplate Context="Item">
                    <input type="number" value="@Item.Quantity" min="1" @onchange="@(async (ChangeEventArgs e) => { Item.Quantity = int.TryParse(e.Value?.ToString(), out var q) ? q : Item.Quantity; })" style="width:60px" />
                </ItemTemplate>
            </TemplateField>
            <TemplateField HeaderText="Item Total">
                <ItemTemplate Context="Item">@(((decimal)(Item.Product?.UnitPrice ?? 0) * Item.Quantity).ToString("c"))</ItemTemplate>
            </TemplateField>
        </Columns>
    </GridView>

    <div>
        <p></p>
        <strong>Order Total: @cartTotal.ToString("c")</strong>
    </div>
    <br />
    <table>
        <tr>
            <td><Button Text="Refresh" OnClick="UpdateBtn_Click" /></td>
            <td><Button Text="Checkout" OnClick="CheckoutBtn_Click" /></td>
        </tr>
    </table>
}
else
{
    <p>Your shopping cart is empty.</p>
}
