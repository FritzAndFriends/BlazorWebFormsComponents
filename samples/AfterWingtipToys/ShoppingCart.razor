@page "/ShoppingCart"

<PageTitle>Shopping Cart</PageTitle>
<Site>
    <ChildComponents>
        <Content ContentPlaceHolderID="MainContent">
            <div class="ContentHead"><h1>@ShoppingCartTitle</h1></div>

            @if (HasItems)
            {
                <form method="post" @formname="shoppingCart">
                    <AntiforgeryToken />
                    <GridView ItemType="CartItem" Items="@CartItems" AutoGenerateColumns="false" CssClass="table table-striped table-bordered">
                        <Columns>
                            <BoundField DataField="ProductId" HeaderText="ID" />
                            <BoundField DataField="Product.ProductName" HeaderText="Name" />
                            <BoundField DataField="Product.UnitPrice" HeaderText="Price (each)" DataFormatString="{0:c}" />
                            <TemplateField HeaderText="Quantity">
                                <ItemTemplate Context="Item">
                                    <input type="number" min="0" class="form-control" style="width: 80px" name="quantity-@Item.ProductId" value="@Item.Quantity" />
                                </ItemTemplate>
                            </TemplateField>
                            <TemplateField HeaderText="Item Total">
                                <ItemTemplate Context="Item">
                                    @(((decimal)(Item.Product?.UnitPrice ?? 0) * Item.Quantity).ToString("c"))
                                </ItemTemplate>
                            </TemplateField>
                            <TemplateField HeaderText="Remove Item">
                                <ItemTemplate Context="Item">
                                    <button type="submit" class="btn btn-default" name="removeProductId" value="@Item.ProductId">Remove</button>
                                </ItemTemplate>
                            </TemplateField>
                        </Columns>
                    </GridView>
                    <div>
                        <p></p>
                        <strong>Order Total: @CartTotal.ToString("c")</strong>
                    </div>
                    <br />
                    <button type="submit" class="btn btn-default" name="action" value="Update">Update</button>
                </form>
            }
            else
            {
                <p>Your shopping cart is empty.</p>
            }
        </Content>
    </ChildComponents>
</Site>