@page "/AdminPage"

<PageTitle>Administration</PageTitle>

<h1>Administration</h1>
<hr />
<h3>Add Product:</h3>
<table>
    <tr>
        <td><Label ID="LabelAddCategory">Category:</Label></td>
        <td>
            <DropDownList ID="DropDownAddCategory" Items="@_categories"
                TItem="Category" DataTextField="CategoryName"
                DataValueField="CategoryID"
                SelectedValueChanged="@(val => _selectedCategoryId = int.TryParse(val, out var v) ? v : 0)" />
        </td>
    </tr>
    <tr>
        <td><Label ID="LabelAddName">Name:</Label></td>
        <td>
            <TextBox ID="AddProductName" Text="@_newProductName" TextChanged="@(val => _newProductName = val)" />
            <RequiredFieldValidator Type="string" ID="RequiredFieldValidator1" Text="* Product name required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic" />
        </td>
    </tr>
    <tr>
        <td><Label ID="LabelAddDescription">Description:</Label></td>
        <td>
            <TextBox ID="AddProductDescription" Text="@_newProductDescription" TextChanged="@(val => _newProductDescription = val)" />
            <RequiredFieldValidator Type="string" ID="RequiredFieldValidator2" Text="* Description required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic" />
        </td>
    </tr>
    <tr>
        <td><Label ID="LabelAddPrice">Price:</Label></td>
        <td>
            <TextBox ID="AddProductPrice" Text="@_newProductPrice" TextChanged="@(val => _newProductPrice = val)" />
            <RequiredFieldValidator Type="string" ID="RequiredFieldValidator3" Text="* Price required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic" />
            <RegularExpressionValidator Type="string" ID="RegularExpressionValidator1" Text="* Must be a valid price without $." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic" ValidationExpression="^[0-9]*(\.)?[0-9]?[0-9]?$" />
        </td>
    </tr>
    <tr>
        <td><Label ID="LabelAddImageFile">Image File:</Label></td>
        <td>
            <FileUpload ID="ProductImage" />
            <RequiredFieldValidator Type="string" ID="RequiredFieldValidator4" Text="* Image path required." SetFocusOnError="true" Display="@ValidatorDisplay.Dynamic" />
        </td>
    </tr>
</table>
<p></p>
<p></p>
<Button ID="AddProductButton" Text="Add Product" OnClick="@OnAddProduct" CausesValidation="true" />
<Label ID="LabelAddStatus" Text="@_addStatus" />
<p></p>
<h3>Remove Product:</h3>
<table>
    <tr>
        <td><Label ID="LabelRemoveProduct">Product:</Label></td>
        <td>
            <DropDownList ID="DropDownRemoveProduct" Items="@_products" TItem="Product" AppendDataBoundItems="true"
                DataTextField="ProductName" DataValueField="ProductID"
                SelectedValueChanged="@(val => _selectedRemoveProductId = int.TryParse(val, out var v) ? v : 0)" />
        </td>
    </tr>
</table>
<p></p>
<Button ID="RemoveProductButton" Text="Remove Product" OnClick="@OnRemoveProduct" CausesValidation="false" />
<Label ID="LabelRemoveStatus" Text="@_removeStatus" />
