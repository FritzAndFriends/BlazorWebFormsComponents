@page "/ProductList"

<PageTitle>Products</PageTitle>

<section>
    <div>
        <hgroup>
            <h2>Products</h2>
        </hgroup>

        <ListView ID="productList" Items="@_products" ItemType="Product"
            DataKeyNames="ProductID" GroupItemCount="4">
            <EmptyDataTemplate>
                <table>
                    <tr>
                        <td>No data was returned.</td>
                    </tr>
                </table>
            </EmptyDataTemplate>
            <EmptyItemTemplate>
                <td />
            </EmptyItemTemplate>
            <GroupTemplate>
                <tr id="itemPlaceholderContainer">
                    @context
                </tr>
            </GroupTemplate>
            <ItemTemplate>
                <td>
                    <table>
                        <tr>
                            <td>
                                <a href="/ProductDetails?productID=@context.ProductID">
                                    <img src="/Catalog/Images/Thumbs/@context.ImagePath"
                                        width="100" height="75" style="border:1px solid" />
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <a href="/ProductDetails?productID=@context.ProductID">
                                    @context.ProductName
                                </a>
                                <br />
                                <span>
                                    <b>Price: </b>@($"{context.UnitPrice:c}")
                                </span>
                                <br />
                                <a href="/AddToCart?productID=@context.ProductID">
                                    <span class="ProductListItem">
                                        <b>Add To Cart</b>
                                    </span>
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td>&nbsp;</td>
                        </tr>
                    </table>
                </td>
            </ItemTemplate>
            <LayoutTemplate>
                <table style="width:100%;">
                    <tbody>
                        <tr>
                            <td>
                                <table id="groupPlaceholderContainer" style="width:100%">
                                    @context
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td></td>
                        </tr>
                        <tr></tr>
                    </tbody>
                </table>
            </LayoutTemplate>
        </ListView>
    </div>
</section>

